 = 100\n","num_batchs = len(data) // batch_size + (1 if len(data) % batch_size > 0 else 0)\n","\n","# Specify the last completed batch\n","start_batch = 0\n","\n","for i in range(start_batch, num_batchs):\n","    # Get the batch of data\n","    batch = data.iloc[i * batch_size:(i + 1) * batch_size]\n","\n","    # Apply summarization to the 'content' column in the batch\n","    batch['summary'] = batch['content'].apply(summarize_text)\n","\n","    # Define the filename for each batch\n","    filename = f'/content/drive/MyDrive/0.SKRIPSI/CODES/Summarize/4_Summary_Suara_Entertain_50_Base1/Sum_Suara_Entertain_50_Base1/Suara_en_sum_50_{i + 1}.csv'\n","\n","    # Save the summarized data to a CSV file\n","    batch[['title', 'category', 'publish_date', 'author', 'article_url', 'content', 'summary']].to_csv(filename, index=False)\n","\n","    print(f\"Summarization for batch {i + 1} completed and saved to {filename}.\")\n","\n","print(\"All remaining batches have been summarized and saved.\")"]},{"cell_type":"code","execution_count":32,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"elapsed":542,"status":"ok","timestamp":1739844171093,"user":{"displayName":"Desak Intan","userId":"12124267034655153145"},"user_tz":-480},"id":"bGHPt4c5mUd8","outputId":"ebbe39ff-b1e8-493f-9783-a5c4a9caca01"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["                        _id  \\\n","0  670a55816b44cf55573d02ce   \n","1  670a55816b44cf55573d02d0   \n","2  670a55816b44cf55573d02d7   \n","3  670a55816b44cf55573d02dd   \n","4  670a55816b44cf55573d02df   \n","\n","                                                                                                      title  \\\n","0                             Tulisan di Kaos Nikita Mirzani Ngeri-Ngeri Sedap: Neraka Takut Gue Ambil Alih   \n","1                  Tak Datang saat Pelantikan DPR, 9 Potret Kedekatan Romy Soekarno dengan Anak Donna Harun   \n","2              Umrah Jadi Pelarian? Paula Verhoeven Temukan Ketenangan di Tengah Isu Cerai dengan Baim Wong   \n","3                       Teori Konspirasi Kematian Michael Jackson dan Terowongan P Diddy Hubungkan Rumah MJ   \n","4  Riwayat Kelam Mertua Sebagai Pejabat Diungkit, Netizen Heran Beby Tsabina Mau Dinikahi Rizki Natakusumah   \n","\n","        category publish_date          author  \\\n","0  Entertainment   2024-10-03    Yazir Farouk   \n","1  Entertainment   2024-10-03   Yohanes Endra   \n","2  Entertainment   2024-10-03  Ferry Noviandi   \n","3  Entertainment   2024-10-03    Rifan Aditya   \n","4  Entertainment   2024-10-03    Yazir Farouk   \n","\n","                                                                                                                                                     article_url  \\\n","0                             https://www.suara.com/entertainment/2024/10/03/183000/tulisan-di-kaos-nikita-mirzani-ngeri-ngeri-sedap-neraka-takut-gue-ambil-alih   \n","1                  https://www.suara.com/entertainment/2024/10/03/181500/tak-datang-saat-pelantikan-dpr-9-potret-kedekatan-romy-soekarno-dengan-anak-donna-harun   \n","2              https://www.suara.com/entertainment/2024/10/03/170431/umrah-jadi-pelarian-paula-verhoeven-temukan-ketenangan-di-tengah-isu-cerai-dengan-baim-wong   \n","3                      https://www.suara.com/entertainment/2024/10/03/162120/teori-konspirasi-kematian-michael-jackson-dan-terowongan-p-diddy-hubungkan-rumah-mj   \n","4  https://www.suara.com/entertainment/2024/10/03/160252/riwayat-kelam-mertua-sebagai-pejabat-diungkit-netizen-heran-beby-tsabina-mau-dinikahi-rizki-natakusumah   \n","\n","                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        content  \n","0                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         Suara.com - Nikita Mirzani baru saja melaporkan Vadel Badjideh dan Razman Arif Nasution ke Polda Metro Jaya, Kamis (3/10/2024).\\nDidampingi pengacaranya Fahmi Bachmid, Nikita Mirzani menebar senyum saat tiba di sana. Ibu tiga anak tersebut optimis memperkarakan kasusnya dengan Vadel Badjideh dan Razman Arif Nasution.\\nAda yang cukup bikin salah fokus. Ini terkait kaos yang dipakai Nikita Mirzani.\\nBaca Juga: Vadel Badjideh Besok Diperiksa Polisi, Nikita Mirzani Tutup Pintu Maaf: Cuih!\\nKaos berwarna hitam tersebut bertuliskan, 'Heaven don't want me. Hell's afraid i'll take over.' Bila diartikan, 'Surga tak menginginkan gue. Neraka takut gue ambil alih.'\\nTulisan dalam kaos Nikita Mirzani seolah menjadi ultimatum kepada seterunya. Pasalnya, neraka saja bisa dia ambil alih.\\nSaat ini, Nikita Mirzani diketahui sedang berkonflik dengan Vadel Badjideh. Artis 38 tahun ini tak terima anaknya dirusak dalam bentuk apapun.\\nKarena itu, Nikita Mirzani melaporkan Vadel Badjideh atas dugaan persetubuhan anak di bawah umur dan atau aborsi yang tak sesuai ketentuan.\\nNikita Mirzani bahkan sudah mengumpulkan sejumlah bukti untuk menjebloskan Vadel Badjideh ke penjara.\\nBaca Juga: Dilaporkan Nikita Mirzani, Vadel Badjideh dan Razman Arif Nasution Terancam 4 Tahun Penjara\\nBukti tersebut mulai dari kesaksian Lolly sebagai korban, hasil visum dan beberapa keterangan saksi lain.  \n","1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      Suara.com - Hendra Rahtomo atau yang lebih dikenal sebagai Romy Soekarno dilantik menjadi anggota DPR pada Selasa (1/10/2024) lalu. Padahal jumlah suara Romy dalam Pemilihan Legislatif (Pileg) 2024 tidak berada di urutan teratas.\\nTernyata Romy Soeharto dilantik menggantikan Sri Rahayu dan Arteria Dahlan yang mengundurkan diri. Namun Romy membantah apabila dibilang diberi kursi oleh mereka, melainkan hasil perjuangannya di daerah pemilihan (dapil) Jawa Timur VI.\\nLatar belakang Romy Soeharto lantas ramai dicari tahu. Romy diketahui sebagai cucu Soekarno, putra almarhumah Rachmawati Soekarnoputri dari Martomo Pariatman Marzuki sang suami pertama.\\nRomy Soeharto secara otomatis juga keponakan Ketua PDIP Megawati Soekarnoputri dan sepupu Ketua DPR RI Puan Maharini. Romy pernah menikah dengan Donna Harun dan memiliki seorang anak, siapa lagi kalau bukan Jeje Soekarno.\\nBaca Juga: Romy Soekarno Anak Siapa? Cucu Presiden Pertama Dapat Kursi DPR Usai Sri Rahayu-Arteria Dahlan Mundur\\nMeski sudah bercerai dari Donna Harun pada 2018, Romy Soeharto rupanya masih dekat dengan anak-anaknya. Tak terkecuali dengan Ricky Harun, putra Donna dari pernikahan pertamanya bersama Ardy Gustav.\\nSeperti apa potret kedekatan Romy Soekarno dengan anak-anak Donna Harun? Simak potret-potretnya berikut ini.\\nJeje Soekarno terbilang hampir tidak pernah membagikan momennya bareng Romy Soekarno. Beda dengan Jeje, Romy selalu mengunggah kebersamaan mereka seperti ketika nyoblos bareng di Pemilu 2024 lalu.\\nDalam berbagai kegiatan keluarga, Jeje Soekarno yang tinggal bersama Donna Harun selalu menyempatkan datang kok. Jeje dan Romy Soekarno terlihat kompak berfoto mengapit lukisan Rachmawati Soekarnoputri yang meninggal dunia pada Juli 2021.\\nMomen Jeje Soekarno merayakan lebaran bareng Rachmawati Soekarnoputri dan Romy Soekarno di masa lalu sekaligus mengungkap hubungan keluarganya. Donna Harun rupanya mengomentari potret lebaran ini sehingga hubungan mereka dipastikan masih sangat baik.\\nBaca Juga: Tak Masalah Posisinya di DPR Digantikan Cucu Soekarno, Arteria: Saya Kerja Melayani Megawati dan Keluarga Besarnya\\nDi usia 26 tahun, hubungan Jeje Soekarno dan Romy Soekarno sang ayah tak disangka sangat dekat meski jarang diperlihatkan. Liburan berdua di luar negeri cukup sering dibagikan Romy melalui Instagram pribadinya.\\nDalam sebuah unggahan Instagram di masa lalu, Jeje Soekarno pernah mengungkap rasa kagumnya kepada Romy Soekarno. Jeje menyebut sang ayah adalah pejuang yang bertahan dalam penderitaan sendirian, sekaligus tetap mendorongnya menjadi sosok terbaik dalam apapun yang ia inginkan.\\nRomy Soekarno bukan hanya dekat dengan Jeje Soekarno, tetapi juga sahabat sang putra salah satunya Shakilla Astari putri Sarita Abdul Mukti dan Faisal Haris. Fakta ini membuktikan bahwa Jeje dan Romy sebenarnya sangat dekat.\\nTak disangka Romy Soekarno juga dekat dengan Ricky Harun yang berstatus putra sambungnya. Bagaimana tidak, Romy dan Donna menikah selama 12 tahun sehingga Ricky pun sudah seperti anaknya sendiri.\\nOleh sebab itu, Romy Soekarno pun telah menjadi kakek dari empat cucu anak-anak Ricky Harun dan Herfiza Novianti. Bahkan setelah bercerai dari Donna Harun, Romy masih temu kangen dengan anak sambung, menantu, dan cucu-cucunya itu.\\nJeje Soekarno yang belakangan dikenal sebagai selebgram ternama di Indonesia agaknya tak punya banyak waktu lagi untuk sang ayah. Maka ketika Jeje sempat menghadiri acara keluarga, Romy sampai berkomentar 'akhirnya'.\\nSaat Romy Soekarno dilantik jadi anggota DPR RI pun, Jeje Soekarno tak terlihat batang hidungnya mendampingi sang ayah. Sehari setelah pelantikan, Jeje justru terlihat baru kembali ke Jakarta.\\nHal itu tentu kontras dengan anak-anak anggota DPR RI yang menghadiri pelantikan orangtua mereka, sebut saja Al Ghazali sahabat Jeje Soekarno hingga Azizah Salsha. Bagaimana pendapatmu?\\nKontributor : Neressa Prahastiwi  \n","2                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      Suara.com - Paula Verhoeven baru-baru ini melakukan ibadah umrah di Tanah Suci. Berangkat sendiri tanpa suami dan anak-anaknya, Paula memanfaatkan momen tersebut untuk lebih mendekatkan diri kepada Tuhan.\\n\"Ini kemarin alhamdulillah punya waktu bisa umrah sendiri jadi ada waktu lebih buat beribadah,\" kata Paula Verhoeven, mengutip dari YouTube Starpro Indonesia.\\n\"Kesempatan umrah kali ini saya gunakan untuk berdoa dan mendekatkan diri pada Allah, memohon petunjuk dan ketenangan hati atas semua yang sedang saya hadapi,\" katanya menyambung.\\nBaca Juga: Paula Verhoeven Ungkap Alasan Umrah Tanpa Baim Wong: Sebenarnya karena Masalah...\\nSelama di Tanah Suci, Paula menjalani ibadah  dengan rekan-rekan artis lainnya yang turut menjalani ibadah umrah.  Di sana, Paula juga mengalami pengalaman spiritual yang biasa dialami kebanyakan mereka yang umrah.\\n\"Alhamdulillah seperti biasa, umrahnya khidmat. Pengalaman spiritual kemarin enggak ada yang gimana, cuma alhamdulillah punya banya waktu untuk ke masjidnya, benar-benar waktu untuk diri sendiri sama Allah,\" ujar Paula.\\nPaula Verhoeven menjelaskan, ibadah umrah yang dilakoninya adalah bagian dari pekerjaan.  Paula mengaku sedang ada pekerjaan di Dubai bersama teman-teman saat itu, kemudian sekalian umrah.\\n\"Memang aku di sana kan kerja ke Dubai juga. Kami memang ada kerjaan sekalian umrah, jadi niatnya memang pengin umrah, terus alhamdulillah ada kerjaan sama teman-teman, ya jadi senang,\" imbuhnya.\\nPaula menuturkan, ia umrah sekaligus bekerja saat itu tidak sendirian. Ia melakoninya bersama Davina Karamoy, Feni Rose, juga Chand Kelvin dan istrinya.\\nBaca Juga: Koar-Koar Dekat dengan Olla Ramlan Hingga Ngaku Sayang, Baim Wong Dinilai Tak Punya Harga Diri\\nSebagai informasi, kepergian Paula Verhoeven umrah tanpa Baim Wong sempat ramai diperbincangkan publik. Hal itu karena dilakoni Paula saat rumah tangganya diterpa kabar miring soal perceraian.\\nDitambah lagi, Baim Wong mengaku tidak tahu istrinya sendiri berangkat umrah. Menurut Baim, Paula tidak meminta izin kepadanya.\\nSementara itu, Paula menyinggung kesibukan Baim membuat mereka tak bisa pergi bersama. Namun, ia bersyukur Baim bisa menjaga anak-anaknya.\\nPaula juga sempat mengunggah story soal kajian soal diam. Dalam konten kajian yang dibagikan Paula, diam lebih baik dibanding bicara yang tidak bermanfaat.  \n","3  Suara.com - Teori konspirasi kematian Michael Jackson masih menjadi pembahasan menarik meski sang legenda telah meninggal dunia pada tahun 2009 silam. Saat ini, kematiannya bahkan kembali menjadi perbincangan karena dikaitkan dengan P Diddy.\\nMeskipun laporan resmi menyatakan bahwa Michael Jackson meninggal akibat overdosis obat yang menyebabkan henti jantung, teori konspirasi tentang penyebab kematiannya terus berkembang di kalangan penggemar dan publik.\\nSalah satu teori yang menarik perhatian adalah dugaan keterlibatan produser musik terkenal, Sean Combs, atau yang lebih dikenal dengan nama P Diddy. Spekulasi ini muncul karena beberapa fakta mencurigakan yang ditemukan seputar hari-hari terakhir kehidupan Michael Jackson.\\nPada pagi hari 25 Juni 2009, Michael Jackson ditemukan tidak sadarkan diri di rumahnya oleh dokter pribadinya, Dr. Conrad Murray. Tak lama setelah dibawa ke rumah sakit, Michael Jackson dinyatakan meninggal.\\nBaca Juga: Imbas Kasus Kekerasan hingga Perdagangan Seksual, P Diddy Dijerat 120 Gugatan Baru\\nHasil autopsi mengungkapkan bahwa penyebab utama kematiannya adalah keracunan propofol, sebuah anestesi kuat yang hanya boleh digunakan di bawah pengawasan medis ketat. Dr. Murray dihukum bersalah atas pembunuhan tidak disengaja pada tahun 2011 karena memberikan propofol tanpa pengawasan yang memadai.\\nSalah satu teori konspirasi yang banyak beredar adalah bahwa Michael Jackson dibunuh. Beberapa orang percaya bahwa kematiannya merupakan bagian dari rencana oleh kekuatan besar yang terlibat dalam bisnis dan industri musik.\\nTeori ini diperkuat oleh pernyataan sang legenda sendiri sebelum kematiannya, di mana ia mengaku merasa terancam dan mengatakan ada orang-orang yang ingin memanfaatkan dirinya.\\nMeskipun Dr. Murray dijatuhi hukuman, beberapa orang meyakini bahwa dia hanya dijadikan kambing hitam, sementara pelaku yang sebenarnya masih menghirup udara bebas.\\nTeori konspirasi lainnya mengklaim bahwa Michael Jackson sebenarnya masih hidup dan hanya memalsukan kematiannya. Beberapa penggemar percaya bahwa ia ingin menghindari sorotan media dan tekanan sebagai selebriti.\\nBaca Juga: Dari Ferrari Hingga Maybach Koleksi Mobil P. Diddy yang Disebut Bagian Identitasnya\\nTeori ini berdasar pada beberapa laporan penampakan orang yang mirip Michael Jackson setelah kematiannya, serta video dan foto yang muncul bertahun-tahun kemudian, yang membuat mereka yakin bahwa ia mungkin masih bersembunyi.\\nSelain itu, ada teori yang menyatakan bahwa industri musik, yang dikenal dengan persaingan dan intrik finansial, turut berperan dalam kematian Michael Jackson. Ia diketahui sering berselisih dengan beberapa tokoh besar dalam industri ini, terutama terkait dengan kontrak dan hak atas katalog musiknya.\\nMeski berbagai teori konspirasi beredar, fakta hukum tetap menunjukkan bahwa Jackson meninggal akibat overdosis propofol. Dr. Murray telah dihukum dan menjalani masa hukuman terkait kasus tersebut.\\nSetelah belasan tahun berlalu, nama rapper dan produser P Diddy dikaitkan dengan kematian Michael Jackson usai kasusnya mencuat baru-baru ini.\\nSeperti yang diketahui, P Diddy didakwa atas berbagai pelanggaran berat, seperti pelecehan seksual, pemerasan, dan prostitusi. Ia bahkan kerap menggelar pesta seks, di mana ia memaksa orang-orang berhubungan seks di bawah pengaruh obat-obatan dan direkam secara ilegal.\\nSpekulasi keterkaitan P Diddy dengan kematian Michael Jackson muncul ke permukaan setelah ditemukan beberapa fakta aneh di hari-hari terakhir Michael Jackson.\\nSalah satu kejanggalan yang ditemukan adalah hubungan Michael Jackson dengan P Diddy. Keduanya pernah bertemu di beberapa kesempatan, bahkan ada foto-foto yang menunjukkan kedekatan mereka. Michael Jackson juga dikabarkan pernah menghadiri pesta yang diadakan oleh P Diddy.\\nTeori ini diperkuat oleh adanya hubungan antara P Diddy dan Fahim Muhammad, mantan kepala keamanan Michael Jackson. Fahim Muhammad diketahui berada di sisi sang penyanyi pada saat-saat terakhir hidupnya.\\nMenariknya, setelah kematian Michael Jackson, Fahim Muhammad bergabung dengan Combs Enterprises, perusahaan milik P Diddy. Banyak yang berpendapat bahwa Fahim mungkin dipengaruhi oleh pihak-pihak tertentu sebelum kematian Michael Jackson.\\nSelain itu, tidak berfungsinya sistem keamanan di rumah Michael Jackson pada hari kematiannya semakin menambah kecurigaan. CCTV di kediamannya dilaporkan rusak, sehingga tidak ada rekaman yang dapat menunjukkan kejadian yang sebenarnya.\\nFahim Muhammad sendiri sempat tersandung kasus kriminal setelah bekerja untuk Combs Enterprises, namun hingga kini belum ada bukti yang mengaitkannya dengan kematian Michael Jackson.\\nMeski begitu, penggemar Michael Jackson masih meyakini bahwa Fahim mungkin telah dimanipulasi oleh orang-orang dalam lingkaran P Diddy. Teori konspirasi semakin berkembang setelah wawancara lama dengan P Diddy dan mantan pasangannya, Kim Porter, kembali beredar.\\nDalam wawancara itu, Porter tampak menghindari pertanyaan tentang Michael Jackson dengan sikap yang aneh, memicu spekulasi bahwa ada sesuatu yang disembunyikan terkait kematiannya.\\nMeskipun teori ini terus berkembang di kalangan penggemar, belum ada bukti yang dapat membuktikan bahwa P Diddy atau Fahim Muhammad terlibat dalam kematian Michael Jackson.\\nMengutip dari Stylecaster, salah satu rumor mengejutkan yang beredar adalah adanya terowongan bawah tanah yang menghubungan P Diddy dengan rumah Michael Jackson.\\nBeberapa unggahan media sosial mengklaim bahwa FBI menemukan terowongan di bawah rumah Diddy yang dulunya terhubung ke ruang bawah tanah di rumah besar Michael Jackson.\\nSeorang pengguna TikTok mengklaim bahwa timnya merasa gugup, memblokir pintu masuk ke rumahnya, dan memohon agar mereka tidak memasuki terowongan tersebut. Video tersebut juga mengklaim bahwa ada pakaian anak-anak yang ditemukan di dalam terowongan tersebut.\\nNamun, hingga saat ini tidak ada sumber kredibel yang mengatakan bahwa Diddy memiliki terowongan penghubung ke rumah Michael Jackson.\\nMeskipun laporan resmi mengaitkan kematian Jackson dengan overdosis obat, spekulasi tentang penyebab kematiannya terus berlanjut. Penggemar masih meyakini bahwa ada banyak hal yang terjadi di balik layar, dan publik masih ingin mendapatkan jawaban pasti atas kematian King of Pop tersebut.\\nDemikianlah informasi mengenai teori konspirasi kematian Michael Jackson, yang baru-baru ini dikaitkan dengan P Diddy.\\nKontributor : Dini Sukmaningtyas  \n","4                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               Suara.com - Nama Beby Tsabina sedang ramai diperbincangkan di platform media sosial X. Sorotan muncul usai beredar potret Beby mendampingi suaminya, Rizki Natakusumah dalam pelantikan anggota DPR RI periode 2024-2029 pada Selasa (1/10/2024) lalu.\\nSebagaimana tersaji di unggahan akun @spherebee, Kamis (3/10/2024), sorotan awalnya bukan ditujukan kepada Beby Tsabina, melainkan Rizki Natakusumah, putra Dimyati Natakusumah yang pernah tersandung kasus korupsi di 2009.\\n\"Ini Natakusumah. Dinasti korup lain di samping Atut di Banten,\" tulis akun tersebut.\\nSejarah kelam Dimyati Natakusumah pun turut dijabarkan secara rinci oleh sang pemilik akun.\\nBaca Juga: Mengenal Sosok Rizki Natakusumah, Suami Beby Tsabina Disebut Netizen 'Kaesang Versi Pandeglang'\\n\"Bapaknya mantan Bupati Pandeglang tahun 2000 sampai 2009. Tersangka kasus korupsi Rp200M, lalu dibebaskan dan malah maju ke DPR periode 2009-2014. Sempet jadi Wakil Ketua MPR beberapa bulan, sebelum akhirnya balik ke DPR sampai tahun 2019,\" papar akun tersebut.\\nLebih jauh lagi, akun @spherebee juga membongkar kasus dugaan pelecehan terhadap anak di bawah umur yang menyeret Dimyati Natakusumah di 2004. Namun saat itu, pemeriksaan terhadap Dimyati terhambat izin Presiden Susilo Bambang Yudhoyono (SBY).\\nSetelah cerita masa lalu Dimyati Natakusumah terungkap, baru lah sorotan bergeser ke Beby Tsabina. Di kolom komentar, ada sejumlah pengguna X yang bertanya kenapa Beby mau jadi mantu pejabat yang banyak kasus seperti Dimyati.\\n\"Kok bisa sih, Beby Tsabina mau nikah dengan orang yang keluarganya punya track record jelek, yang jelas terpampang nyata? Kalau soal duit, harusnya dia bisa dapet yang lebih kaya sih,\" kata pemilik akun @anakbungsu.\\n\"Sebelum nikah, apa nggak ngecek background-nya dulu ya? Kok mau-mau aja sama yang punya jejak koruptor gitu?,\" ujar pemilik akun @belumsaatnya.\\nBaca Juga: Potret Rizki Natakusumah dan Beby Tsabina Saat Pelantikan DPR, Publik: Kaesang-Erina Versi Good Looking\\nNamun di sisi lain, ada juga yang tidak mau mengaitkan masa lalu Dimyati Natakusumah dengan pernikahan Beby Tsabina dan Rizki Natakusumah.\\n\"Sempet iri sama kehidupan Beby, jujur aja. Karier, pertemanan, nikah muda, semua lancar. Pas tahu fakta tentang suaminya, jadi nggak iri lagi. Jujur, sedikit menyayangkan. Tapi mungkin udah jodohnya ya,\" kata pemilik akun @sheandwhite.\\nDimyati Natakusumah sendiri kini bakal bertarung di Pilkada Banten sebagai calon wakil gubernur, mendampingi Andra Soni. Keduanya diusung Gerindra, PKS, Demokrat, PAN, PSI, Nasdem, PKB, PPP, Partai Prima dan Partai Garuda.  "],"text/html":["\n","  <div id=\"df-8861486a-2734-4c4f-bf91-12a184ffefa0\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>_id</th>\n","      <th>title</th>\n","      <th>category</th>\n","      <th>publish_date</th>\n","      <th>author</th>\n","      <th>article_url</th>\n","      <th>content</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>670a55816b44cf55573d02ce</td>\n","      <td>Tulisan di Kaos Nikita Mirzani Ngeri-Ngeri Sedap: Neraka Takut Gue Ambil Alih</td>\n","      <td>Entertainment</td>\n","      <td>2024-10-03</td>\n","      <td>Yazir Farouk</td>\n","      <td>https://www.suara.com/entertainment/2024/10/03/183000/tulisan-di-kaos-nikita-mirzani-ngeri-ngeri-sedap-neraka-takut-gue-ambil-alih</td>\n","      <td>Suara.com - Nikita Mirzani baru saja melaporkan Vadel Badjideh dan Razman Arif Nasution ke Polda Metro Jaya, Kamis (3/10/2024).\\nDidampingi pengacaranya Fahmi Bachmid, Nikita Mirzani menebar senyum saat tiba di sana. Ibu tiga anak tersebut optimis memperkarakan kasusnya dengan Vadel Badjideh dan Razman Arif Nasution.\\nAda yang cukup bikin salah fokus. Ini terkait kaos yang dipakai Nikita Mirzani.\\nBaca Juga: Vadel Badjideh Besok Diperiksa Polisi, Nikita Mirzani Tutup Pintu Maaf: Cuih!\\nKaos berwarna hitam tersebut bertuliskan, 'Heaven don't want me. Hell's afraid i'll take over.' Bila diartikan, 'Surga tak menginginkan gue. Neraka takut gue ambil alih.'\\nTulisan dalam kaos Nikita Mirzani seolah menjadi ultimatum kepada seterunya. Pasalnya, neraka saja bisa dia ambil alih.\\nSaat ini, Nikita Mirzani diketahui sedang berkonflik dengan Vadel Badjideh. Artis 38 tahun ini tak terima anaknya dirusak dalam bentuk apapun.\\nKarena itu, Nikita Mirzani melaporkan Vadel Badjideh atas dugaan persetubuhan anak di bawah umur dan atau aborsi yang tak sesuai ketentuan.\\nNikita Mirzani bahkan sudah mengumpulkan sejumlah bukti untuk menjebloskan Vadel Badjideh ke penjara.\\nBaca Juga: Dilaporkan Nikita Mirzani, Vadel Badjideh dan Razman Arif Nasution Terancam 4 Tahun Penjara\\nBukti tersebut mulai dari kesaksian Lolly sebagai korban, hasil visum dan beberapa keterangan saksi lain.</td>\n","    </tr>\n","    <tr>\n","      <th>1</th>\n","      <td>670a55816b44cf55573d02d0</td>\n","      <td>Tak Datang saat Pelantikan DPR, 9 Potret Kedekatan Romy Soekarno dengan Anak Donna Harun</td>\n","      <td>Entertainment</td>\n","      <td>2024-10-03</td>\n","      <td>Yohanes Endra</td>\n","      <td>https://www.suara.com/entertainment/2024/10/03/181500/tak-datang-saat-pelantikan-dpr-9-potret-kedekatan-romy-soekarno-dengan-anak-donna-harun</td>\n","      <td>Suara.com - Hendra Rahtomo atau yang lebih dikenal sebagai Romy Soekarno dilantik menjadi anggota DPR pada Selasa (1/10/2024) lalu. Padahal jumlah suara Romy dalam Pemilihan Legislatif (Pileg) 2024 tidak berada di urutan teratas.\\nTernyata Romy Soeharto dilantik menggantikan Sri Rahayu dan Arteria Dahlan yang mengundurkan diri. Namun Romy membantah apabila dibilang diberi kursi oleh mereka, melainkan hasil perjuangannya di daerah pemilihan (dapil) Jawa Timur VI.\\nLatar belakang Romy Soeharto lantas ramai dicari tahu. Romy diketahui sebagai cucu Soekarno, putra almarhumah Rachmawati Soekarnoputri dari Martomo Pariatman Marzuki sang suami pertama.\\nRomy Soeharto secara otomatis juga keponakan Ketua PDIP Megawati Soekarnoputri dan sepupu Ketua DPR RI Puan Maharini. Romy pernah menikah dengan Donna Harun dan memiliki seorang anak, siapa lagi kalau bukan Jeje Soekarno.\\nBaca Juga: Romy Soekarno Anak Siapa? Cucu Presiden Pertama Dapat Kursi DPR Usai Sri Rahayu-Arteria Dahlan Mundur\\nMeski sudah bercerai dari Donna Harun pada 2018, Romy Soeharto rupanya masih dekat dengan anak-anaknya. Tak terkecuali dengan Ricky Harun, putra Donna dari pernikahan pertamanya bersama Ardy Gustav.\\nSeperti apa potret kedekatan Romy Soekarno dengan anak-anak Donna Harun? Simak potret-potretnya berikut ini.\\nJeje Soekarno terbilang hampir tidak pernah membagikan momennya bareng Romy Soekarno. Beda dengan Jeje, Romy selalu mengunggah kebersamaan mereka seperti ketika nyoblos bareng di Pemilu 2024 lalu.\\nDalam berbagai kegiatan keluarga, Jeje Soekarno yang tinggal bersama Donna Harun selalu menyempatkan datang kok. Jeje dan Romy Soekarno terlihat kompak berfoto mengapit lukisan Rachmawati Soekarnoputri yang meninggal dunia pada Juli 2021.\\nMomen Jeje Soekarno merayakan lebaran bareng Rachmawati Soekarnoputri dan Romy Soekarno di masa lalu sekaligus mengungkap hubungan keluarganya. Donna Harun rupanya mengomentari potret lebaran ini sehingga hubungan mereka dipastikan masih sangat baik.\\nBaca Juga: Tak Masalah Posisinya di DPR Digantikan Cucu Soekarno, Arteria: Saya Kerja Melayani Megawati dan Keluarga Besarnya\\nDi usia 26 tahun, hubungan Jeje Soekarno dan Romy Soekarno sang ayah tak disangka sangat dekat meski jarang diperlihatkan. Liburan berdua di luar negeri cukup sering dibagikan Romy melalui Instagram pribadinya.\\nDalam sebuah unggahan Instagram di masa lalu, Jeje Soekarno pernah mengungkap rasa kagumnya kepada Romy Soekarno. Jeje menyebut sang ayah adalah pejuang yang bertahan dalam penderitaan sendirian, sekaligus tetap mendorongnya menjadi sosok terbaik dalam apapun yang ia inginkan.\\nRomy Soekarno bukan hanya dekat dengan Jeje Soekarno, tetapi juga sahabat sang putra salah satunya Shakilla Astari putri Sarita Abdul Mukti dan Faisal Haris. Fakta ini membuktikan bahwa Jeje dan Romy sebenarnya sangat dekat.\\nTak disangka Romy Soekarno juga dekat dengan Ricky Harun yang berstatus putra sambungnya. Bagaimana tidak, Romy dan Donna menikah selama 12 tahun sehingga Ricky pun sudah seperti anaknya sendiri.\\nOleh sebab itu, Romy Soekarno pun telah menjadi kakek dari empat cucu anak-anak Ricky Harun dan Herfiza Novianti. Bahkan setelah bercerai dari Donna Harun, Romy masih temu kangen dengan anak sambung, menantu, dan cucu-cucunya itu.\\nJeje Soekarno yang belakangan dikenal sebagai selebgram ternama di Indonesia agaknya tak punya banyak waktu lagi untuk sang ayah. Maka ketika Jeje sempat menghadiri acara keluarga, Romy sampai berkomentar 'akhirnya'.\\nSaat Romy Soekarno dilantik jadi anggota DPR RI pun, Jeje Soekarno tak terlihat batang hidungnya mendampingi sang ayah. Sehari setelah pelantikan, Jeje justru terlihat baru kembali ke Jakarta.\\nHal itu tentu kontras dengan anak-anak anggota DPR RI yang menghadiri pelantikan orangtua mereka, sebut saja Al Ghazali sahabat Jeje Soekarno hingga Azizah Salsha. Bagaimana pendapatmu?\\nKontributor : Neressa Prahastiwi</td>\n","    </tr>\n","    <tr>\n","      <th>2</th>\n","      <td>670a55816b44cf55573d02d7</td>\n","      <td>Umrah Jadi Pelarian? Paula Verhoeven Temukan Ketenangan di Tengah Isu Cerai dengan Baim Wong</td>\n","      <td>Entertainment</td>\n","      <td>2024-10-03</td>\n","      <td>Ferry Noviandi</td>\n","      <td>https://www.suara.com/entertainment/2024/10/03/170431/umrah-jadi-pelarian-paula-verhoeven-temukan-ketenangan-di-tengah-isu-cerai-dengan-baim-wong</td>\n","      <td>Suara.com - Paula Verhoeven baru-baru ini melakukan ibadah umrah di Tanah Suci. Berangkat sendiri tanpa suami dan anak-anaknya, Paula memanfaatkan momen tersebut untuk lebih mendekatkan diri kepada Tuhan.\\n\"Ini kemarin alhamdulillah punya waktu bisa umrah sendiri jadi ada waktu lebih buat beribadah,\" kata Paula Verhoeven, mengutip dari YouTube Starpro Indonesia.\\n\"Kesempatan umrah kali ini saya gunakan untuk berdoa dan mendekatkan diri pada Allah, memohon petunjuk dan ketenangan hati atas semua yang sedang saya hadapi,\" katanya menyambung.\\nBaca Juga: Paula Verhoeven Ungkap Alasan Umrah Tanpa Baim Wong: Sebenarnya karena Masalah...\\nSelama di Tanah Suci, Paula menjalani ibadah  dengan rekan-rekan artis lainnya yang turut menjalani ibadah umrah.  Di sana, Paula juga mengalami pengalaman spiritual yang biasa dialami kebanyakan mereka yang umrah.\\n\"Alhamdulillah seperti biasa, umrahnya khidmat. Pengalaman spiritual kemarin enggak ada yang gimana, cuma alhamdulillah punya banya waktu untuk ke masjidnya, benar-benar waktu untuk diri sendiri sama Allah,\" ujar Paula.\\nPaula Verhoeven menjelaskan, ibadah umrah yang dilakoninya adalah bagian dari pekerjaan.  Paula mengaku sedang ada pekerjaan di Dubai bersama teman-teman saat itu, kemudian sekalian umrah.\\n\"Memang aku di sana kan kerja ke Dubai juga. Kami memang ada kerjaan sekalian umrah, jadi niatnya memang pengin umrah, terus alhamdulillah ada kerjaan sama teman-teman, ya jadi senang,\" imbuhnya.\\nPaula menuturkan, ia umrah sekaligus bekerja saat itu tidak sendirian. Ia melakoninya bersama Davina Karamoy, Feni Rose, juga Chand Kelvin dan istrinya.\\nBaca Juga: Koar-Koar Dekat dengan Olla Ramlan Hingga Ngaku Sayang, Baim Wong Dinilai Tak Punya Harga Diri\\nSebagai informasi, kepergian Paula Verhoeven umrah tanpa Baim Wong sempat ramai diperbincangkan publik. Hal itu karena dilakoni Paula saat rumah tangganya diterpa kabar miring soal perceraian.\\nDitambah lagi, Baim Wong mengaku tidak tahu istrinya sendiri berangkat umrah. Menurut Baim, Paula tidak meminta izin kepadanya.\\nSementara itu, Paula menyinggung kesibukan Baim membuat mereka tak bisa pergi bersama. Namun, ia bersyukur Baim bisa menjaga anak-anaknya.\\nPaula juga sempat mengunggah story soal kajian soal diam. Dalam konten kajian yang dibagikan Paula, diam lebih baik dibanding bicara yang tidak bermanfaat.</td>\n","    </tr>\n","    <tr>\n","      <th>3</th>\n","      <td>670a55816b44cf55573d02dd</td>\n","      <td>Teori Konspirasi Kematian Michael Jackson dan Terowongan P Diddy Hubungkan Rumah MJ</td>\n","      <td>Entertainment</td>\n","      <td>2024-10-03</td>\n","      <td>Rifan Aditya</td>\n","      <td>https://www.suara.com/entertainment/2024/10/03/162120/teori-konspirasi-kematian-michael-jackson-dan-terowongan-p-diddy-hubungkan-rumah-mj</td>\n","      <td>Suara.com - Teori konspirasi kematian Michael Jackson masih menjadi pembahasan menarik meski sang legenda telah meninggal dunia pada tahun 2009 silam. Saat ini, kematiannya bahkan kembali menjadi perbincangan karena dikaitkan dengan P Diddy.\\nMeskipun laporan resmi menyatakan bahwa Michael Jackson meninggal akibat overdosis obat yang menyebabkan henti jantung, teori konspirasi tentang penyebab kematiannya terus berkembang di kalangan penggemar dan publik.\\nSalah satu teori yang menarik perhatian adalah dugaan keterlibatan produser musik terkenal, Sean Combs, atau yang lebih dikenal dengan nama P Diddy. Spekulasi ini muncul karena beberapa fakta mencurigakan yang ditemukan seputar hari-hari terakhir kehidupan Michael Jackson.\\nPada pagi hari 25 Juni 2009, Michael Jackson ditemukan tidak sadarkan diri di rumahnya oleh dokter pribadinya, Dr. Conrad Murray. Tak lama setelah dibawa ke rumah sakit, Michael Jackson dinyatakan meninggal.\\nBaca Juga: Imbas Kasus Kekerasan hingga Perdagangan Seksual, P Diddy Dijerat 120 Gugatan Baru\\nHasil autopsi mengungkapkan bahwa penyebab utama kematiannya adalah keracunan propofol, sebuah anestesi kuat yang hanya boleh digunakan di bawah pengawasan medis ketat. Dr. Murray dihukum bersalah atas pembunuhan tidak disengaja pada tahun 2011 karena memberikan propofol tanpa pengawasan yang memadai.\\nSalah satu teori konspirasi yang banyak beredar adalah bahwa Michael Jackson dibunuh. Beberapa orang percaya bahwa kematiannya merupakan bagian dari rencana oleh kekuatan besar yang terlibat dalam bisnis dan industri musik.\\nTeori ini diperkuat oleh pernyataan sang legenda sendiri sebelum kematiannya, di mana ia mengaku merasa terancam dan mengatakan ada orang-orang yang ingin memanfaatkan dirinya.\\nMeskipun Dr. Murray dijatuhi hukuman, beberapa orang meyakini bahwa dia hanya dijadikan kambing hitam, sementara pelaku yang sebenarnya masih menghirup udara bebas.\\nTeori konspirasi lainnya mengklaim bahwa Michael Jackson sebenarnya masih hidup dan hanya memalsukan kematiannya. Beberapa penggemar percaya bahwa ia ingin menghindari sorotan media dan tekanan sebagai selebriti.\\nBaca Juga: Dari Ferrari Hingga Maybach Koleksi Mobil P. Diddy yang Disebut Bagian Identitasnya\\nTeori ini berdasar pada beberapa laporan penampakan orang yang mirip Michael Jackson setelah kematiannya, serta video dan foto yang muncul bertahun-tahun kemudian, yang membuat mereka yakin bahwa ia mungkin masih bersembunyi.\\nSelain itu, ada teori yang menyatakan bahwa industri musik, yang dikenal dengan persaingan dan intrik finansial, turut berperan dalam kematian Michael Jackson. Ia diketahui sering berselisih dengan beberapa tokoh besar dalam industri ini, terutama terkait dengan kontrak dan hak atas katalog musiknya.\\nMeski berbagai teori konspirasi beredar, fakta hukum tetap menunjukkan bahwa Jackson meninggal akibat overdosis propofol. Dr. Murray telah dihukum dan menjalani masa hukuman terkait kasus tersebut.\\nSetelah belasan tahun berlalu, nama rapper dan produser P Diddy dikaitkan dengan kematian Michael Jackson usai kasusnya mencuat baru-baru ini.\\nSeperti yang diketahui, P Diddy didakwa atas berbagai pelanggaran berat, seperti pelecehan seksual, pemerasan, dan prostitusi. Ia bahkan kerap menggelar pesta seks, di mana ia memaksa orang-orang berhubungan seks di bawah pengaruh obat-obatan dan direkam secara ilegal.\\nSpekulasi keterkaitan P Diddy dengan kematian Michael Jackson muncul ke permukaan setelah ditemukan beberapa fakta aneh di hari-hari terakhir Michael Jackson.\\nSalah satu kejanggalan yang ditemukan adalah hubungan Michael Jackson dengan P Diddy. Keduanya pernah bertemu di beberapa kesempatan, bahkan ada foto-foto yang menunjukkan kedekatan mereka. Michael Jackson juga dikabarkan pernah menghadiri pesta yang diadakan oleh P Diddy.\\nTeori ini diperkuat oleh adanya hubungan antara P Diddy dan Fahim Muhammad, mantan kepala keamanan Michael Jackson. Fahim Muhammad diketahui berada di sisi sang penyanyi pada saat-saat terakhir hidupnya.\\nMenariknya, setelah kematian Michael Jackson, Fahim Muhammad bergabung dengan Combs Enterprises, perusahaan milik P Diddy. Banyak yang berpendapat bahwa Fahim mungkin dipengaruhi oleh pihak-pihak tertentu sebelum kematian Michael Jackson.\\nSelain itu, tidak berfungsinya sistem keamanan di rumah Michael Jackson pada hari kematiannya semakin menambah kecurigaan. CCTV di kediamannya dilaporkan rusak, sehingga tidak ada rekaman yang dapat menunjukkan kejadian yang sebenarnya.\\nFahim Muhammad sendiri sempat tersandung kasus kriminal setelah bekerja untuk Combs Enterprises, namun hingga kini belum ada bukti yang mengaitkannya dengan kematian Michael Jackson.\\nMeski begitu, penggemar Michael Jackson masih meyakini bahwa Fahim mungkin telah dimanipulasi oleh orang-orang dalam lingkaran P Diddy. Teori konspirasi semakin berkembang setelah wawancara lama dengan P Diddy dan mantan pasangannya, Kim Porter, kembali beredar.\\nDalam wawancara itu, Porter tampak menghindari pertanyaan tentang Michael Jackson dengan sikap yang aneh, memicu spekulasi bahwa ada sesuatu yang disembunyikan terkait kematiannya.\\nMeskipun teori ini terus berkembang di kalangan penggemar, belum ada bukti yang dapat membuktikan bahwa P Diddy atau Fahim Muhammad terlibat dalam kematian Michael Jackson.\\nMengutip dari Stylecaster, salah satu rumor mengejutkan yang beredar adalah adanya terowongan bawah tanah yang menghubungan P Diddy dengan rumah Michael Jackson.\\nBeberapa unggahan media sosial mengklaim bahwa FBI menemukan terowongan di bawah rumah Diddy yang dulunya terhubung ke ruang bawah tanah di rumah besar Michael Jackson.\\nSeorang pengguna TikTok mengklaim bahwa timnya merasa gugup, memblokir pintu masuk ke rumahnya, dan memohon agar mereka tidak memasuki terowongan tersebut. Video tersebut juga mengklaim bahwa ada pakaian anak-anak yang ditemukan di dalam terowongan tersebut.\\nNamun, hingga saat ini tidak ada sumber kredibel yang mengatakan bahwa Diddy memiliki terowongan penghubung ke rumah Michael Jackson.\\nMeskipun laporan resmi mengaitkan kematian Jackson dengan overdosis obat, spekulasi tentang penyebab kematiannya terus berlanjut. Penggemar masih meyakini bahwa ada banyak hal yang terjadi di balik layar, dan publik masih ingin mendapatkan jawaban pasti atas kematian King of Pop tersebut.\\nDemikianlah informasi mengenai teori konspirasi kematian Michael Jackson, yang baru-baru ini dikaitkan dengan P Diddy.\\nKontributor : Dini Sukmaningtyas</td>\n","    </tr>\n","    <tr>\n","      <th>4</th>\n","      <td>670a55816b44cf55573d02df</td>\n","      <td>Riwayat Kelam Mertua Sebagai Pejabat Diungkit, Netizen Heran Beby Tsabina Mau Dinikahi Rizki Natakusumah</td>\n","      <td>Entertainment</td>\n","      <td>2024-10-03</td>\n","      <td>Yazir Farouk</td>\n","      <td>https://www.suara.com/entertainment/2024/10/03/160252/riwayat-kelam-mertua-sebagai-pejabat-diungkit-netizen-heran-beby-tsabina-mau-dinikahi-rizki-natakusumah</td>\n","      <td>Suara.com - Nama Beby Tsabina sedang ramai diperbincangkan di platform media sosial X. Sorotan muncul usai beredar potret Beby mendampingi suaminya, Rizki Natakusumah dalam pelantikan anggota DPR RI periode 2024-2029 pada Selasa (1/10/2024) lalu.\\nSebagaimana tersaji di unggahan akun @spherebee, Kamis (3/10/2024), sorotan awalnya bukan ditujukan kepada Beby Tsabina, melainkan Rizki Natakusumah, putra Dimyati Natakusumah yang pernah tersandung kasus korupsi di 2009.\\n\"Ini Natakusumah. Dinasti korup lain di samping Atut di Banten,\" tulis akun tersebut.\\nSejarah kelam Dimyati Natakusumah pun turut dijabarkan secara rinci oleh sang pemilik akun.\\nBaca Juga: Mengenal Sosok Rizki Natakusumah, Suami Beby Tsabina Disebut Netizen 'Kaesang Versi Pandeglang'\\n\"Bapaknya mantan Bupati Pandeglang tahun 2000 sampai 2009. Tersangka kasus korupsi Rp200M, lalu dibebaskan dan malah maju ke DPR periode 2009-2014. Sempet jadi Wakil Ketua MPR beberapa bulan, sebelum akhirnya balik ke DPR sampai tahun 2019,\" papar akun tersebut.\\nLebih jauh lagi, akun @spherebee juga membongkar kasus dugaan pelecehan terhadap anak di bawah umur yang menyeret Dimyati Natakusumah di 2004. Namun saat itu, pemeriksaan terhadap Dimyati terhambat izin Presiden Susilo Bambang Yudhoyono (SBY).\\nSetelah cerita masa lalu Dimyati Natakusumah terungkap, baru lah sorotan bergeser ke Beby Tsabina. Di kolom komentar, ada sejumlah pengguna X yang bertanya kenapa Beby mau jadi mantu pejabat yang banyak kasus seperti Dimyati.\\n\"Kok bisa sih, Beby Tsabina mau nikah dengan orang yang keluarganya punya track record jelek, yang jelas terpampang nyata? Kalau soal duit, harusnya dia bisa dapet yang lebih kaya sih,\" kata pemilik akun @anakbungsu.\\n\"Sebelum nikah, apa nggak ngecek background-nya dulu ya? Kok mau-mau aja sama yang punya jejak koruptor gitu?,\" ujar pemilik akun @belumsaatnya.\\nBaca Juga: Potret Rizki Natakusumah dan Beby Tsabina Saat Pelantikan DPR, Publik: Kaesang-Erina Versi Good Looking\\nNamun di sisi lain, ada juga yang tidak mau mengaitkan masa lalu Dimyati Natakusumah dengan pernikahan Beby Tsabina dan Rizki Natakusumah.\\n\"Sempet iri sama kehidupan Beby, jujur aja. Karier, pertemanan, nikah muda, semua lancar. Pas tahu fakta tentang suaminya, jadi nggak iri lagi. Jujur, sedikit menyayangkan. Tapi mungkin udah jodohnya ya,\" kata pemilik akun @sheandwhite.\\nDimyati Natakusumah sendiri kini bakal bertarung di Pilkada Banten sebagai calon wakil gubernur, mendampingi Andra Soni. Keduanya diusung Gerindra, PKS, Demokrat, PAN, PSI, Nasdem, PKB, PPP, Partai Prima dan Partai Garuda.</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div>\n","    <div class=\"colab-df-buttons\">\n","\n","  <div class=\"colab-df-container\">\n","    <button class=\"colab-df-convert\" onclick=\"convertToInteractive('df-8861486a-2734-4c4f-bf91-12a184ffefa0')\"\n","            title=\"Convert this dataframe to an interactive table.\"\n","            style=\"display:none;\">\n","\n","  <svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\" viewBox=\"0 -960 960 960\">\n","    <path d=\"M120-120v-720h720v720H120Zm60-500h600v-160H180v160Zm220 220h160v-160H400v160Zm0 220h160v-160H400v160ZM180-400h160v-160H180v160Zm440 0h160v-160H620v160ZM180-180h160v-160H180v160Zm440 0h160v-160H620v160Z\"/>\n","  </svg>\n","    </button>\n","\n","  <style>\n","    .colab-df-container {\n","      display:flex;\n","      gap: 12px;\n","    }\n","\n","    .colab-df-convert {\n","      background-color: #E8F0FE;\n","      border: none;\n","      border-radius: 50%;\n","      cursor: pointer;\n","      display: none;\n","      fill: #1967D2;\n","      height: 32px;\n","      padding: 0 0 0 0;\n","      width: 32px;\n","    }\n","\n","    .colab-df-convert:hover {\n","      background-color: #E2EBFA;\n","      box-shadow: 0px 1px 2px rgba(60, 64, 67, 0.3), 0px 1px 3px 1px rgba(60, 64, 67, 0.15);\n","      fill: #174EA6;\n","    }\n","\n","    .colab-df-buttons div {\n","      margin-bottom: 4px;\n","    }\n","\n","    [theme=dark] .colab-df-convert {\n","      background-color: #3B4455;\n","      fill: #D2E3FC;\n","    }\n","\n