escription\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":12}]},{"cell_type":"code","source":["print(df.dtypes)  # Untuk melihat tipe data kolom"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Xux4hSzGSYnT","executionInfo":{"status":"ok","timestamp":1739840913525,"user_tz":-480,"elapsed":13,"user":{"displayName":"Desak Intan","userId":"12124267034655153145"}},"outputId":"7748d828-9364-4286-b31b-ca7b7a66efe3"},"execution_count":13,"outputs":[{"output_type":"stream","name":"stdout","text":["_id                     object\n","title                   object\n","category                object\n","publish_date    datetime64[ns]\n","author                  object\n","article_url             object\n","content                 object\n","dtype: object\n"]}]},{"cell_type":"markdown","source":["## Delete data other than months 7-9"],"metadata":{"id":"n1SxWrm4UHf6"}},{"cell_type":"code","source":["# Filter untuk bulan Juli, Agustus, dan September (bulan 7, 8, 9)\n","pre_data = df[df['publish_date'].dt.month.isin([7, 8, 9])]\n","\n","# Hasil\n","pre_data.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":642},"id":"RZFwkW3FUGgo","executionInfo":{"status":"ok","timestamp":1739840915540,"user_tz":-480,"elapsed":1486,"user":{"displayName":"Desak Intan","userId":"12124267034655153145"}},"outputId":"014d9276-182c-48fb-8059-84eeba993206"},"execution_count":14,"outputs":[{"output_type":"execute_result","data":{"text/plain":["                          _id  \\\n","267  670a55816b44cf55573d03f9   \n","268  670a55816b44cf55573d03fc   \n","269  670a55816b44cf55573d03fe   \n","270  670a55816b44cf55573d0405   \n","280  670a55816b44cf55573d03f7   \n","\n","                                                 title       category  \\\n","267  Tiba-Tiba Jadi Suami Beristri Dua di Film, Ibr...  Entertainment   \n","268  Rujuk dengan Ira Nandha, Elmer Syaherman Terny...  Entertainment   \n","269  Sudah Keluar, Hasil Visum Lolly untuk Bukt