ile/CODES/Summarize/5_Summary_Suara_Nasional_50_Base1/Sum_Suara_Nasional_50_Base1/Suara_nas_sum_50_{i + 1}.csv'\n","\n","    # Save the summarized data to a CSV file\n","    batch[['title', 'category', 'publish_date', 'author', 'article_url', 'content', 'summary']].to_csv(filename, index=False)\n","\n","    print(f\"Summarization for batch {i + 1} completed and saved to {filename}.\")\n","\n","print(\"All remaining batches have been summarized and saved.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"bGHPt4c5mUd8"},"outputs":[],"source":["df.head()"]}]}