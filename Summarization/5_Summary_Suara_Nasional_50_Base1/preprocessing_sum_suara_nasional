markdown","source":["## Change Month on Sentance"],"metadata":{"id":"zCxnlImQmjIg"}},{"cell_type":"code","source":["# Fungsi untuk mengubah format tanggal\n","def format_date(text):\n","    # Menggunakan regex untuk mencari tanggal dalam format (dd/mm/yyyy)\n","    def replace_date(match):\n","        day = match.group(1)\n","        month = match.group(2)\n","        year = match.group(3)\n","        month_names = [\n","            \"Januari\", \"Februari\", \"Maret\", \"April\", \"Mei\", \"Juni\",\n","            \"Juli\", \"Agustus\", \"September\", \"Oktober\", \"November\", \"Desember\"\n","        ]\n","\n","        # Pengecekan untuk memastikan bulan valid\n","        month_index = int(month) - 1\n","        if 0 <= month_index < len(month_names):  # Cek apakah bulan dalam rentang valid\n","            return f\"{day} {month_names[month_index]} {year}\"\n","        else:\n","            return match.group(0)  # Jika tidak valid, kembalikan string asli\n","\n","    # Mengganti setiap tanggal yang ditemukan\n","    return re.sub(r'\\((\\d{1,2})/(\\d{1,2})/(\\d{4})\\)', replace_date, text)\n","\n","# Mengubah format tanggal dalam kolom 'content'\n","pre_data['content'] = pre_data['content'].apply(format_date)"],"metadata":{"id":"kvV3ZuJjcrk1","executionInfo":{"status":"ok","timestamp":1739858430899,"user_tz":-480,"elapsed":10,"user":{"displayName":"Picessa Kresna","userId":"07281084735981375061"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"8d99e4f4-c29c-4873-f5bb-7660c2c4766b"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stderr","text":["<ipython-input-20-4749465816ee>:24: SettingWithCopyWarning: \n","A value is trying to be set on a copy of a slice from a DataFrame.\n","Try using .loc[row_indexer,col_indexer] = value instead\n","\n","See the caveats in the documentation: https://pandas.pydata.org/pandas-docs/stable/user_guide/indexing.html#returning-a-view-versus-a-copy\n","  pre_data['content'] = pre_data['content'].apply(format_date)\n"]}]},{"cell_type":"code","source":["# Mengatur opsi tampilan pandas agar tidak terpotong\n","pd.set_option('display.max_colwidth', None)  # Mengatur lebar kolom maksimum menjadi None\n","\n","# Menampilkan DataFrame\n","pre_data.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"S-Vdy4YnmxJ3","executionInfo":{"status":"ok","timestamp":1739858431298,"user_tz":-480,"elapsed":406,"user":{"displayName":"Picessa Kresna","userId":"07281084735981375061"}},"outputId":"28bdc503-3a70-4382-8cc4-795515d80410"},"execution_count":21,"outputs":[{"output_type":"execute_result","data":{"text/plain":["                        _id  \\\n","0  670a56d16b44cf55573d2ce2   \n","1  670a56d16b44cf55573d2ce8   \n","2  670a56d16b44cf55573d2ced   \n","3  670a56d16b44cf55573d2cf7   \n","4  670a56d16b44cf55573d2cf9   \n","\n","                                                                                                   title  \\\n","0                     Jokowi Beberkan 'Love-Hate' dengan Surya Paloh; Nggak Papa, Saya Kira Sangat Bagus   \n","1                       Ucap Terima Kasih, Surya Paloh Akui Belajar dari Politik Jokowi, Begini Katanya!   \n","2         Di Depan Jokowi, Surya Paloh: Bukan Cuma Masalah Kursi Menteri yang Diharapkan NasDem, tapi...   \n","3  Jokowi Muncul di Kongres III NasDem Malam Ini, Prabowo Disebut Menyusul: Tak Ada yang Tak Kami Undang   \n","4                              Sebut Pemilu 2024 Paling Brutal, Cak Imin Usul Sistem Pemilu Diubah Total   \n","\n","   category publish_date               author  \\\n","0  Nasional   2024-08-26    Chandra Iswinarno   \n","1  Nasional   2024-08-25  Agung Sandy Lesmana   \n","2  Nasional   2024-08-25  Agung Sandy Lesmana   \n","3  Nasional   2024-08-25  Agung Sandy Lesmana   \n","4  Nasional   2024-08-25       Bangun Santoso   \n","\n","                                                                                                                                        article_url  \\\n","0                       https://www.suara.com/news/2024/08/26/070000/jokowi-beberkan-love-hate-dengan-surya-paloh-nggak-papa-saya-kira-sangat-bagus   \n","1                        https://www.suara.com/news/2024/08/25/224500/ucap-terima-kasih-surya-paloh-akui-belajar-dari-politik-jokowi-begini-katanya   \n","2             https://www.suara.com/news/2024/08/25/214434/di-depan-jokowi-surya-paloh-bukan-cuma-masalah-kursi-menteri-yang-diharapkan-nasdem-tapi   \n","3  https://www.suara.com/news/2024/08/25/194135/jokowi-muncul-di-kongres-iii-nasdem-malam-ini-prabowo-disebut-menyusul-tak-ada-yang-tak-kami-undang   \n","4                             https://www.suara.com/news/2024/08/25/184735/sebut-pemilu-2024-paling-brutal-cak-imin-usul-sistem-pemilu-diubah-total   \n","\n","                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  content  \n","0                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 Presiden Joko Widodo atau Jokowi membeberkan bahwa Ketua Umum Partai NasDem Surya Paloh merupakan ketua umum partai yang paling banyak ia temui.\\nBahkan, Jokowi paling banyak mengajak Paloh untuk berdiskusi ketimbang ketum parpol lainnya.\\n\"Partner diskusi politik saya yang paling banyak kami bertukar pikiran mengenai masa depan bangsa, mengenai gagasan masa depan kita, dan lain-lainnya,\" kata Jokowi di pembukaan Kongres ke-3 NasDem di JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nJokowi lantas menyinggung perbedaan jalan dengan Paloh. Tetapi ia memaklumi adanya perbedaan tersebut.\\nBaca Juga: Usai Dukung Jokowi, Surya Paloh Tegaskan NasDem Mantap Berlabuh ke Prabowo di 2024\\n\"Ya, walaupun di 2024, sempat beda jalan, Bang Surya di satu perubahan, kemudian yang satunya di keberlanjutan. Ya ndak papa, itu wajar. Kita bisa saling memahami dan kita bisa saling mengerti mengenai perbedaan itu,\" kata Jokowi.\\nJokowi menegaskan hubungannya dengan Paloh berlangsung secara natural, sangat alami, sangat nyata, dan apa adanya.\\n\"Kami bisa sangat dekat, walaupun juga sering berbeda pendapat. Kami bisa saling menemukan kecocokan walau juga banyak di tengah-tengah itu tidak ada kecocokan,\" kata Jokowi.\\n\"Kami bisa saling mengerti, walau kadang-kadang setelah mengerti juga bingung sendiri-sendiri,\" sambungnya.\\nMantan Wali Kota Solo ini lantas menyinggung perbedaan antara dirinya dengan Surya Paloh. Padahal satu minggu sebelumnya, ia dan Paloh menyepakati hal yang sama sampai bersalaman.\\nBaca Juga: Ucap Terima Kasih, Surya Paloh Akui Belajar dari Politik Jokowi, Begini Katanya!\\n\"Saya pernah salaman hari ini salaman, sepakat, lalu seminggu kemudian beda. Nggak papa, saya kira sangat bagus,\" ujar Jokowi.  \n","1                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Ketua Umum Partai NasDem Surya Paloh mengaku banyak pembelajaran politik yang dipetik dari Presiden Jokowi. Mengingat NasDem sudah 10 tahun bersama-sama dengan Jokowi.\\nSurya Paloh menyampaikan terima kasih atas pembelajaran politik yang banyak diberikan Jokowi.\\n\"Kami harus berterima kasih kepada Pak Jokowi, Anda telah memberikan banyak kepada NasDem ini satu pembelajaran politik,\" kata Paloh dalam pidatonya di Kongres III Partai NasDem, JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nSurya Paloh menyampaikan apa hal yang membuat ia belajar dari kepemimpinan Jokowi selama hamlir 10 tahun. Hasil dari belajar tersebut, Surya Paloh merasa hidup tidak hanya bermodal niat baik.\\nBaca Juga: Surya Paloh: Di Akhir Masa Jabatannya, Presiden Jokowi Tetap Sahabat NasDem\\n\"Dari pembelajaran ini saya bisa memahami hidup memang bukan hanya bermodalkan niat baik semata mata, niat baik itu sewajarnya dan mestinya, tapi juga harus ada strategi yang tepat,\" kata Paloh.\\nSurya Paloh lantas menyinggung Ketua Umum Partai Golkar Bahlil Lahadalia yang ia nilai bisa menjabat, bila hidup hanya bermodal niat baik tanpa strategi yang tidak tepat\\n\"Begitu niat baik saja, strategi tidak tepat, nah Bung Bahlil itu bisa menjawabnya sebagai adik saya,\" kata Paloh.  \n","2  Ketua Umum Partai NasDem Surya Paloh menegaskan ingin menjadi partai peringan di pemerintahan Presiden Jokowi, bukan sebaliknya menjadi partai pemberat. Hal itu disampaikan Paloh dalam pidatonya di pembukaan Kongres ke-3 Partai NasDem yang turut dihadiri oleh Jokowi.\\nDalam orasi politiknya, Surya Paloh berujar NasDem berupaya untuk mempertahankan integritas, bukan sebagai partai pemberat bagi pemerintahan.\\n\"Tapi Insyaallah berupaya untuk menjadi peringan beban bagi pemerintahan yang didukung,\" ujarnya di JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nSurya Paloh lantas bicara mengenai kursi jabatan menteri. Ia menegakan, hal tersebut yang bukan dipemermasalahkan NasDem.\\nBaca Juga: Akui Bebas Bicara hingga Kerap Tak Sepakat, Surya Paloh ke Jokowi: Apa Kurangnya NasDem?\\n\"Bukan permasalahan kursi jabatan menteri yang hanya diharapkan oleh partai ini. Kami menghargai itu semuanya, tapi penghargaan kita adalah ketika idea dan pemikiran didengar dan apalagi jika itu mampu kita jalankan itu yang diperjuangkan oleh NasDem,\" ujar Paloh.\\n\"Itulah gerakan perubahan untuk merestorasi bangsa ini,\" sambungnya.\\nTanya Kekurangan NasDem ke Jokowi\\nDalam pidatonya, Surya Paloh juga blak-blakan bertanya soal kekurangan partainya langsung di depan Jokowi. Hal itu dipertanyakan Surya Paloh saat menegaskan NasDem tetap mendukung pemerintahan Jokowi yang hampir 10 tahun berjalan.\\nAwalnya, Surya Paloh menyampaikan perjalanan NasDem dan Jokowi yang sudah selama 10 tahun, terhitung sejak partainya mengusung Jokowi sebagai presiden pada 2014 lalu.\\nBaca Juga: Blak-blakan di Depan Jokowi, Surya Paloh Ungkit Siasat Tambah UU Bikin Blunder: Kita Akhirnya Terjebak!\\nSurya Paloh menyebut hubungan yang berjalan terjalin secara equal partnership, antara pemerintahan yang dipimpin Jokowi dengan NasDem.\\nKendati ada persamaan dan perbedaan dalam hubungan yang terjalin.\\nKita bebas bergerak, berbicara, mengeluarkan pendapat, sepakat, dan kadang-kadang tidak sepakat,\" kata Surya Paloh dalam pidato di Kongres ke-3 NasDem di JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nSurya Paloh menganggap wajar dinamika yang terjadi. Menurutnya dinamika tersebut menunjukan adanya suatu nilai dari perspektif pandangan untuk mencari kesamaan demi kesamaan, bukan perbedaan untuk berbeda.\\n\"Inilah yang menyebabkan satu proses perjalanan hampir 10 tahun ini, kadang-kadang bisa tersenyum lebar kadang-kadang kita harus termagu-magu kadang-kadang kita harus bisa terhenyak duduk sedikit, memikirkan apa sebenarnya yang kurang dengan NasDem ini?\" tanya Paloh di hadapan Jokowi.  \n","3                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Presiden Joko Widodo alias Jokowi menghadiri Kongres III Partai NasDem di Balai Sidang Jakarta (JCC), Jakarta, Minggu 25 Agustus 2024 malam. Presiden Jokowi tiba di lokasi acara sekitar pukul 18.50 WIB mengenakan kemeja lengan panjang berwarna biru tua.\\nTampak menyambut kedatangan Presiden Jokowi, yaitu Ketua Umum DPP Partai NasDem Surya Paloh, Sekretaris Jenderal Partai NasDem Hermawi Taslim, dan Bendahara Umum Partai NasDem Ahmad Sahroni.\\nKongres III Partai NasDem yang dijadwalkan berlangsung 25–27 Agustus 2024 mengundang seluruh partai politik karena merupakan momentum rekonsiliasi.\\n\"Tidak ada yang tidak kita undang, jadi semua partai politik kita undang karena inilah momentum untuk rekonsiliasi. Tidak hanya manis di bibir tapi pahit di kenyataan,\" tutur Ketua Panitia Pengarah Kongres III Partai NasDem Willy Aditya di Jakarta, Jumat (23/8).\\nBaca Juga: Viral Lagi! Kaesang-Erina Kepergok Borong Tas Dior Pakai Jet Pribadi, Akun Jubir Kemenkeu dan Bea Cukai Ramai Dicolek\\nWilly mengatakan selain mengundang Presiden RI Joko Widodo, NasDem juga mengundang Presiden Terpilih Prabowo Subianto.\\n\"Jadi, kemungkinan Pak Prabowo juga datang pada pembukaan dan penutupan. Tapi, secara formal pembukaan oleh Presiden Jokowi, penutupan oleh Pak Prabowo sebagai presiden terpilih,\" ujarnya.\\nIa menambahkan nantinya akan ada tiga komisi dalam pelaksanaan Kongres III Partai NasDem, yakni Komisi AD/ART, Komisi Rekomendasi, dan Komisi Program Aksi. (Antara)  \n","4                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     Ketua Umum Dewan Pimpinan Pusat Partai Kebangkitan Bangsa Muhaimin Iskandar mengusulkan sistem pemilihan umum di Indonesia diubah total agar menjadi lebih baik dan manusiawi dibanding sistem yang berlaku saat ini.\\n\"Pemilu ini sistemnya betul-betul memakan sesama warga bangsa, kompetisinya sadis, uang menjadi panglima, sehingga kami harus bekerja all out (total, red) pada orang-orang yang tidak memiliki biaya,\" kata Cak Imin, sapaan akrabnya, saat memberikan keterangan pers usai Muktamar VI PKB di Bali Nusa Dua Convention Center, Kabupaten Badung, Bali, Minggu 25 Agustus 2024.\\nPadahal, kata Cak Imin, pemilu seharusnya dibuat senyaman dan seaman mungkin bagi rakyat.\\n\"Oleh karena itu, saya akan mengusulkan kepada DPR, kepada presiden, untuk mengubah sistem pemilu yang lebih manusiawi,\" ujarnya sebagaimana dilansir Antara.\\nBaca Juga: Resmi Hasil Muktamar, PKB Nyatakan Gabung Pemerintahan Prabowo-Gibran\\nSebelumnya, saat memberikan pemaparan pada Muktamar VI PKB, Cak Imin mengatakan bahwa Pemilu 2024 merupakan pemilu yang paling brutal.\\n\"Brutal dalam cara kompetisi, brutal dalam cara menggunakan uang untuk kemenangan, brutal dalam segala cara untuk memfitnah,\" jelasnya.\\nMeskipun demikian, Cak Imin mengatakan bahwa kader maupun calon anggota legislatif PKB dapat menghadapi tantangan atau hambatan untuk memperoleh suara yang signifikan.\\nIa mencontohkan beberapa kenaikan perolehan kursi seperti di Aceh yang meningkat tajam dari tiga kursi menjadi sembilan kursi. Kemudian di Jakarta dari lima kursi menjadi sepuluh kursi, hingga di Nusa Tenggara Barat terdapat sebuah daerah pemilihan yang hanya mengakomodasi tiga caleg, tetapi hasilnya menunjukkan caleg PKB berhasil menduduki posisi nomor satu.\\nBaca Juga: Pidato Ma'ruf Amin Di Penutupan Muktamar PKB: Kalau Bisa Milih, Semua Ingin Jadi Anak Presiden  "],"text/html":["\n","  <div id=\"df-a0cccbe0-c123-45c5-8857-52c82827de32\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>_id</th>\n","      <th>title</th>\n","      <th>category</th>\n","      <th>publish_date</th>\n","      <th>author</th>\n","      <th>article_url</th>\n","      <th>content</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>670a56d16b44cf55573d2ce2</td>\n","      <td>Jokowi Beberkan 'Love-Hate' dengan Surya Paloh; Nggak Papa, Saya Kira Sangat Bagus</td>\n","      <td>Nasional</td>\n","      <td>2024-08-26</td>\n","      <td>Chandra Iswinarno</td>\n","      <td>https://www.suara.com/news/2024/08/26/070000/jokowi-beberkan-love-hate-dengan-surya-paloh-nggak-papa-saya-kira-sangat-bagus</td>\n","      <td>Presiden Joko Widodo atau Jokowi membeberkan bahwa Ketua Umum Partai NasDem Surya Paloh merupakan ketua umum partai yang paling banyak ia temui.\\nBahkan, Jokowi paling banyak mengajak Paloh untuk berdiskusi ketimbang ketum parpol lainnya.\\n\"Partner diskusi politik saya yang paling banyak kami bertukar pikiran mengenai masa depan bangsa, mengenai gagasan masa depan kita, dan lain-lainnya,\" kata Jokowi di pembukaan Kongres ke-3 NasDem di JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nJokowi lantas menyinggung perbedaan jalan dengan Paloh. Tetapi ia memaklumi adanya perbedaan tersebut.\\nBaca Juga: Usai Dukung Jokowi, Surya Paloh Tegaskan NasDem Mantap Berlabuh ke Prabowo di 2024\\n\"Ya, walaupun di 2024, sempat beda jalan, Bang Surya di satu perubahan, kemudian yang satunya di keberlanjutan. Ya ndak papa, itu wajar. Kita bisa saling memahami dan kita bisa saling mengerti mengenai perbedaan itu,\" kata Jokowi.\\nJokowi menegaskan hubungannya dengan Paloh berlangsung secara natural, sangat alami, sangat nyata, dan apa adanya.\\n\"Kami bisa sangat dekat, walaupun juga sering berbeda pendapat. Kami bisa saling menemukan kecocokan walau juga banyak di tengah-tengah itu tidak ada kecocokan,\" kata Jokowi.\\n\"Kami bisa saling mengerti, walau kadang-kadang setelah mengerti juga bingung sendiri-sendiri,\" sambungnya.\\nMantan Wali Kota Solo ini lantas menyinggung perbedaan antara dirinya dengan Surya Paloh. Padahal satu minggu sebelumnya, ia dan Paloh menyepakati hal yang sama sampai bersalaman.\\nBaca Juga: Ucap Terima Kasih, Surya Paloh Akui Belajar dari Politik Jokowi, Begini Katanya!\\n\"Saya pernah salaman hari ini salaman, sepakat, lalu seminggu kemudian beda. Nggak papa, saya kira sangat bagus,\" ujar Jokowi.</td>\n","    </tr>\n","    <tr>\n","      <th>1</th>\n","      <td>670a56d16b44cf55573d2ce8</td>\n","      <td>Ucap Terima Kasih, Surya Paloh Akui Belajar dari Politik Jokowi, Begini Katanya!</td>\n","      <td>Nasional</td>\n","      <td>2024-08-25</td>\n","      <td>Agung Sandy Lesmana</td>\n","      <td>https://www.suara.com/news/2024/08/25/224500/ucap-terima-kasih-surya-paloh-akui-belajar-dari-politik-jokowi-begini-katanya</td>\n","      <td>Ketua Umum Partai NasDem Surya Paloh mengaku banyak pembelajaran politik yang dipetik dari Presiden Jokowi. Mengingat NasDem sudah 10 tahun bersama-sama dengan Jokowi.\\nSurya Paloh menyampaikan terima kasih atas pembelajaran politik yang banyak diberikan Jokowi.\\n\"Kami harus berterima kasih kepada Pak Jokowi, Anda telah memberikan banyak kepada NasDem ini satu pembelajaran politik,\" kata Paloh dalam pidatonya di Kongres III Partai NasDem, JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nSurya Paloh menyampaikan apa hal yang membuat ia belajar dari kepemimpinan Jokowi selama hamlir 10 tahun. Hasil dari belajar tersebut, Surya Paloh merasa hidup tidak hanya bermodal niat baik.\\nBaca Juga: Surya Paloh: Di Akhir Masa Jabatannya, Presiden Jokowi Tetap Sahabat NasDem\\n\"Dari pembelajaran ini saya bisa memahami hidup memang bukan hanya bermodalkan niat baik semata mata, niat baik itu sewajarnya dan mestinya, tapi juga harus ada strategi yang tepat,\" kata Paloh.\\nSurya Paloh lantas menyinggung Ketua Umum Partai Golkar Bahlil Lahadalia yang ia nilai bisa menjabat, bila hidup hanya bermodal niat baik tanpa strategi yang tidak tepat\\n\"Begitu niat baik saja, strategi tidak tepat, nah Bung Bahlil itu bisa menjawabnya sebagai adik saya,\" kata Paloh.</td>\n","    </tr>\n","    <tr>\n","      <th>2</th>\n","      <td>670a56d16b44cf55573d2ced</td>\n","      <td>Di Depan Jokowi, Surya Paloh: Bukan Cuma Masalah Kursi Menteri yang Diharapkan NasDem, tapi...</td>\n","      <td>Nasional</td>\n","      <td>2024-08-25</td>\n","      <td>Agung Sandy Lesmana</td>\n","      <td>https://www.suara.com/news/2024/08/25/214434/di-depan-jokowi-surya-paloh-bukan-cuma-masalah-kursi-menteri-yang-diharapkan-nasdem-tapi</td>\n","      <td>Ketua Umum Partai NasDem Surya Paloh menegaskan ingin menjadi partai peringan di pemerintahan Presiden Jokowi, bukan sebaliknya menjadi partai pemberat. Hal itu disampaikan Paloh dalam pidatonya di pembukaan Kongres ke-3 Partai NasDem yang turut dihadiri oleh Jokowi.\\nDalam orasi politiknya, Surya Paloh berujar NasDem berupaya untuk mempertahankan integritas, bukan sebagai partai pemberat bagi pemerintahan.\\n\"Tapi Insyaallah berupaya untuk menjadi peringan beban bagi pemerintahan yang didukung,\" ujarnya di JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nSurya Paloh lantas bicara mengenai kursi jabatan menteri. Ia menegakan, hal tersebut yang bukan dipemermasalahkan NasDem.\\nBaca Juga: Akui Bebas Bicara hingga Kerap Tak Sepakat, Surya Paloh ke Jokowi: Apa Kurangnya NasDem?\\n\"Bukan permasalahan kursi jabatan menteri yang hanya diharapkan oleh partai ini. Kami menghargai itu semuanya, tapi penghargaan kita adalah ketika idea dan pemikiran didengar dan apalagi jika itu mampu kita jalankan itu yang diperjuangkan oleh NasDem,\" ujar Paloh.\\n\"Itulah gerakan perubahan untuk merestorasi bangsa ini,\" sambungnya.\\nTanya Kekurangan NasDem ke Jokowi\\nDalam pidatonya, Surya Paloh juga blak-blakan bertanya soal kekurangan partainya langsung di depan Jokowi. Hal itu dipertanyakan Surya Paloh saat menegaskan NasDem tetap mendukung pemerintahan Jokowi yang hampir 10 tahun berjalan.\\nAwalnya, Surya Paloh menyampaikan perjalanan NasDem dan Jokowi yang sudah selama 10 tahun, terhitung sejak partainya mengusung Jokowi sebagai presiden pada 2014 lalu.\\nBaca Juga: Blak-blakan di Depan Jokowi, Surya Paloh Ungkit Siasat Tambah UU Bikin Blunder: Kita Akhirnya Terjebak!\\nSurya Paloh menyebut hubungan yang berjalan terjalin secara equal partnership, antara pemerintahan yang dipimpin Jokowi dengan NasDem.\\nKendati ada persamaan dan perbedaan dalam hubungan yang terjalin.\\nKita bebas bergerak, berbicara, mengeluarkan pendapat, sepakat, dan kadang-kadang tidak sepakat,\" kata Surya Paloh dalam pidato di Kongres ke-3 NasDem di JCC Senayan, Jakarta, Minggu 25 Agustus 2024.\\nSurya Paloh menganggap wajar dinamika yang terjadi. Menurutnya dinamika tersebut menunjukan adanya suatu nilai dari perspektif pandangan untuk mencari kesamaan demi kesamaan, bukan perbedaan untuk berbeda.\\n\"Inilah yang menyebabkan satu proses perjalanan hampir 10 tahun ini, kadang-kadang bisa tersenyum lebar kadang-kadang kita harus termagu-magu kadang-kadang kita harus bisa terhenyak duduk sedikit, memikirkan apa sebenarnya yang kurang dengan NasDem ini?\" tanya Paloh di hadapan Jokowi.</td>\n","    </tr>\n","    <tr>\n","      <th>3</th>\n","      <td>670a56d16b44cf55573d2cf7</td>\n","      <td>Jokowi Muncul di Kongres III NasDem Malam Ini, Prabowo Disebut Menyusul: Tak Ada yang Tak Kami Undang</td>\n","      <td>Nasional</td>\n","      <td>2024-08-25</td>\n","      <td>Agung Sandy Lesmana</td>\n","      <td>https://www.suara.com/news/2024/08/25/194135/jokowi-muncul-di-kongres-iii-nasdem-malam-ini-prabowo-disebut-menyusul-tak-ada-yang-tak-kami-undang</td>\n","      <td>Presiden Joko Widodo alias Jokowi menghadiri Kongres III Partai NasDem di Balai Sidang Jakarta (JCC), Jakarta, Minggu 25 Agustus 2024 malam. Presiden Jokowi tiba di lokasi acara sekitar pukul 18.50 WIB mengenakan kemeja lengan panjang berwarna biru tua.\\nTampak menyambut kedatangan Presiden Jokowi, yaitu Ketua Umum DPP Partai NasDem Surya Paloh, Sekretaris Jenderal Partai NasDem Hermawi Taslim, dan Bendahara Umum Partai NasDem Ahmad Sahroni.\\nKongres III Partai NasDem yang dijadwalkan berlangsung 25–27 Agustus 2024 mengundang seluruh partai politik karena merupakan momentum rekonsiliasi.\\n\"Tidak ada yang tidak kita undang, jadi semua partai politik kita undang karena inilah momentum untuk rekonsiliasi. Tidak hanya manis di bibir tapi pahit di kenyataan,\" tutur Ketua Panitia Pengarah Kongres III Partai NasDem Willy Aditya di Jakarta, Jumat (23/8).\\nBaca Juga: Viral Lagi! Kaesang-Erina Kepergok Borong Tas Dior Pakai Jet Pribadi, Akun Jubir Kemenkeu dan Bea Cukai Ramai Dicolek\\nWilly mengatakan selain mengundang Presiden RI Joko Widodo, NasDem juga mengundang Presiden Terpilih Prabowo Subianto.\\n\"Jadi, kemungkinan Pak Prabowo juga datang pada pembukaan dan penutupan. Tapi, secara formal pembukaan oleh Presiden Jokowi, penutupan oleh Pak Prabowo sebagai presiden terpilih,\" ujarnya.\\nIa menambahkan nantinya akan ada tiga komisi dalam pelaksanaan Kongres III Partai NasDem, yakni Komisi AD/ART, Komisi Rekomendasi, dan Komisi Program Aksi. (Antara)</td>\n","    </tr>\n","    <tr>\n","      <th>4</th>\n","      <td>670a56d16b44cf55573d2cf9</td>\n","      <td>Sebut Pemilu 2024 Paling Brutal, Cak Imin Usul Sistem Pemilu Diubah Total</td>\n","      <td>Nasional</td>\n","      <td>2024-08-25</td>\n","      <td>Bangun Santoso</td>\n","      <td>https://www.suara.com/news/2024/08/25/184735/sebut-pemilu-2024-paling-brutal-cak-imin-usul-sistem-pemilu-diubah-total</td>\n","      <td>Ketua Umum Dewan Pimpinan Pusat Partai Kebangkitan Bangsa Muhaimin Iskandar mengusulkan sistem pemilihan umum di Indonesia diubah total agar menjadi lebih baik dan manusiawi dibanding sistem yang berlaku saat ini.\\n\"Pemilu ini sistemnya betul-betul memakan sesama warga bangsa, kompetisinya sadis, uang menjadi panglima, sehingga kami harus bekerja all out (total, red) pada orang-orang yang tidak memiliki biaya,\" kata Cak Imin, sapaan akrabnya, saat memberikan keterangan pers usai Muktamar VI PKB di Bali Nusa Dua Convention Center, Kabupaten Badung, Bali, Minggu 25 Agustus 2024.\\nPadahal, kata Cak Imin, pemilu seharusnya dibuat senyaman dan seaman mungkin bagi rakyat.\\n\"Oleh karena itu, saya akan mengusulkan kepada DPR, kepada presiden, untuk mengubah sistem pemilu yang lebih manusiawi,\" ujarnya sebagaimana dilansir Antara.\\nBaca Juga: Resmi Hasil Muktamar, PKB Nyatakan Gabung Pemerintahan Prabowo-Gibran\\nSebelumnya, saat memberikan pemaparan pada Muktamar VI PKB, Cak Imin mengatakan bahwa Pemilu 2024 merupakan pemilu yang paling brutal.\\n\"Brutal dalam cara kompetisi, brutal dalam cara menggunakan uang untuk kemenangan, brutal dalam segala cara untuk memfitnah,\" jelasnya.\\nMeskipun demikian, Cak Imin mengatakan bahwa kader maupun calon anggota legislatif PKB dapat menghadapi tantangan atau hambatan untuk memperoleh suara yang signifikan.\\nIa mencontohkan beberapa kenaikan perolehan kursi seperti di Aceh yang meningkat tajam dari tiga kursi menjadi sembilan kursi. Kemudian di Jakarta dari lima kursi menjadi sepuluh kurs