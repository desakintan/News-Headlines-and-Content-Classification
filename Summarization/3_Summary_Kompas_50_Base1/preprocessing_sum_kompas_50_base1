nfig, and tokenizer\n","custom_config = AutoConfig.from_pretrained(pretrained_model_name_or_path=\"indobenchmark/indobert-base-p1\")\n","custom_config.output_hidden_states = True\n","custom_tokenizer = AutoTokenizer.from_pretrained(pretrained_model_name_or_path=\"indobenchmark/indobert-base-p1\")\n","custom_model = AutoModel.from_pretrained(\"indobenchmark/indobert-base-p1\", config=custom_config)\n","\n","# Instantiate summarizer model\n","model = Summarizer(custom_model=custom_model, custom_tokenizer=custom_tokenizer)\n","\n","# Function to summarize content\n","def summarize_text(text):\n","    summary = model(text, ratio=0.5)  # Ringkasan 40% dari total teks\n","    return summary\n","\n","# Process the DataFrame in chunks of 100 rows\n","batch_size = 100\n","num_batchs = len(data) // batch_size + (1 if len(data) % batch_size > 0 else 0)\n","\n","# Specify the last completed batch\n","start_batch = 0\n","\n","for i in range(start_batch, num_batchs):\n","    # Get the batch of data\n","    batch = data.iloc[i * batch_size:(i + 1) * batch_size]\n","\n","    # Apply summarization to the 'content' column in the batch\n","    batch['summary'] = batch['content'].apply(summarize_text)\n","\n","    # Define the filename for each batch\n","    filename = f'/content/drive/MyDrive/File/CODES/Summarize/3_Summary_Kompas_50_Base1/Sum_Kompas_50_Base1/Kompas_sum_50_{i + 1}.csv'\n","\n","    # Save the summarized data to a CSV file\n","    batch[['title', 'category', 'publish_date', 'author', 'article_url', 'content', 'summary']].to_csv(filename, index=False)\n","\n","    print(f\"Summarization for batch {i + 1} completed and saved to {filename}.\")\n","\n","print(\"All remaining batches have been summarized and saved.\")"]},{"cell_type":"code","execution_count":50,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"executionInfo":{"elapsed":8,"status":"ok","timestamp":1739789616562,"user":{"displayName":"P Kresna","userId":"15164161428322332112"},"user_tz":