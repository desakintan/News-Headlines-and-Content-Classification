 from CSV\n","data = pd.read_csv('/content/drive/MyDrive/File/CODES/Summarize/2_Summary_Detik_Hot_50_Base1/detik_hot_pre_50_base1.csv')\n","\n","# Load model, config, and tokenizer\n","custom_config = AutoConfig.from_pretrained(pretrained_model_name_or_path=\"indobenchmark/indobert-base-p1\")\n","custom_config.output_hidden_states = True\n","custom_tokenizer = AutoTokenizer.from_pretrained(pretrained_model_name_or_path=\"indobenchmark/indobert-base-p1\")\n","custom_model = AutoModel.from_pretrained(\"indobenchmark/indobert-base-p1\", config=custom_config)\n","\n","# Instantiate summarizer model\n","model = Summarizer(custom_model=custom_model, custom_tokenizer=custom_tokenizer)\n","\n","# Function to summarize content\n","def summarize_text(text):\n","    summary = model(text, ratio=0.5)  # Ringkasan 50% dari total teks\n","    return summary\n","\n","# Process the DataFrame in chunks of 100 rows\n","batch_size = 100\n","num_batchs = len(data) // batch_size + (1 if len(data) % batch_size > 0 else 0)\n","\n","# Specify the last completed batch\n","start_batch = 0\n","\n","for i in range(start_batch, num_batchs):\n","    # Get the batch of data\n","    batch = data.iloc[i * batch_size:(i + 1) * batch_size]\n","\n","    # Apply summarization to the 'content' column in the batch\n","    batch['summary'] = batch['content'].apply(summarize_text)\n","\n","    # Define the filename for each batch\n","    filename = f'/content/drive/MyDrive/File/CODES/Summarize/2_Summary_Detik_Hot_50_Base1/Sum_Detik_Hot_50_Base1/Hot_sum_50_base1_{i + 1}.csv'\n","\n","    # Save the summarized data to a CSV file\n","    batch[['title', 'category', 'publish_date', 'author', 'article_url', 'content', 'summary']].to_csv(filename, index=False)\n","\n","    print(f\"Summarization for batch {i + 1} completed and saved to {filename}.\")\n","\n","print(\"All remaining batches have been summarized and saved.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"elapsed":6,"status":"ok","timestamp":1739491794723,"user":{"displayName":"P Kresna","userId":"15164161428322332112"},"user_tz":-480},"id":"bGHPt4c5mUd8","outputId":"a6bc0069-781d-417c-a768-5feddd8734a7"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["                        _id  \\\n","0  672389536403ebe3a5d75ca5   \n","1  672389536403ebe3a5d75ca2   \n","2  672389536403ebe3a5d75ca3   \n","3  672389536403ebe3a5d75ca9   \n","4  672389536403ebe3a5d75cb9   \n","\n","                                                                            title  \\\n","0              Pentingnya Hak Cipta dan Perlakuan Maksimal untuk Para Pelaku Seni   \n","1    Okan Kornelius Pakai Kemeja Pink dan Dapat Kejutan dari Pacar di Ultah ke-45   \n","2                                    Ayu Ting Ting Putus dengan Muhammad Fardhana   \n","3                                Dion Wiyoko Ajak Anak Muda Tak Takut Berkeringat   \n","4  Denny Sumargo Ungkap Kondisi Janin di Kandungan Olivia Allan Jelang Melahirkan   \n","\n","   category publish_date  \\\n","0  detikHot   2024-07-01   \n","1  detikHot   2024-07-01   \n","2  detikHot   2024-07-01   \n","3  detikHot   2024-07-01   \n","4  detikHot   2024-07-01   \n","\n","                                                                                                            article_url  \\\n","0              https://hot.detik.com/music/d-7417986/pentingnya-hak-cipta-dan-perlakuan-maksimal-untuk-para-pelaku-seni   \n","1    https://hot.detik.com/celeb/d-7417696/okan-kornelius-pakai-kemeja-pink-dan-dapat-kejutan-dari-pacar-di-ultah-ke-45   \n","2                                    https://hot.detik.com/celeb/d-7418047/ayu-ting-ting-putus-dengan-muhammad-fardhana   \n","3                          https://hot.detik.com/hottainment/d-7417905/dion-wiyoko-ajak-anak-muda-tak-takut-berkeringat   \n","4  https://hot.detik.com/celeb/d-7416625/denny-sumargo-ungkap-kondisi-janin-di-kandungan-olivia-allan-jelang-melahirkan   \n","\n","                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      content  \\\n","0  Perseteruan Ahmad Dhani dan Once beberapa waktu lalu soal royalti izin membawakan lagu Dewa 19 sempat dianggap sebagai drama oleh netizen. Nyatanya, hal itu sangat berpengaruh bagi keberlangsungan hidup musisi dan orang belakang layar dari kesuksesan sebuah karya. Pembahasan itu pula yang dibahas pada event TimeOut episode 3 IP:101 Own and Protect Your Creative Works oleh Ratri Ninditya. Melalui hasil penelitiannya di Koalisi Seni Indonesia bertajuk Diam-diam Merugikan, ia mengupas ketimpangan royalti di kalangan musisi.    \"Hak cipta tidak pernah memberikan perlindungan maksimal bagi musisi, namun hanya untuk pihak-pihak perantara (label rekaman, platform digital, dan sebagainya),\" kata Ratri lewat acara yang berlangsung di kawasan Tanah Abang, Jakarta Pusat, belum lama ini. Wanita yang akrab disapa Ninin itu juga menyoroti masih kurangnya undang-undang hak cipta di Indonesia yang masih jauh tertinggal. Kendati tidak mewajarkan, polemik Ahmad Dhani dengan Once cukup dipahami Ninin yang menempatkan diri sebagai pencipta karya. \"Musisi atau pelaku pertunjukan belum dapat perlakuan maksimal, hal ini terjadi karena adanya undang-undang hak cipta yang mengatur semua karya yang masuk ke ranah digital menjadi komersil,\" tuturnya. \"Kalau di era dulu, musisi jualan lagu 1 juta keping, hasilnya bisa beli rumah dan mobil. Sekarang?\" sambungnya menggambarkan jelas ironi musisi di era digital ini. Selain Ratri Ninditya, acara yang diinisiasi oleh Asian Creative and Digital Economy Youth Summit (ACE-YS) ini turut menghadirkan pakar seperti Mochtar Sarman dan Rahadian Agung. Pada kesempatan tersebut, ketiganya menyatakan perlu danya kolaborasi berbagai pihak dari seluruh sektor, termasuk pemerintah, demi kemajuan industry kreatif di Indonesia. Perlu diketahui, event TimeOut sendiri merupakan wadah bagi anak muda kreatif untuk beristirahat sejenak dan bertukar pikiran, terhubung, juga mengeksplorasi berbagai perspektif dengan para pakar dan praktisi industri.   \n","1                                                                                                                                                                                                       Artis Okan Kornelius saat ini diketahui tengah menjalin hubungan dengan Angeline Valesques. Saat ulang tahun Okan Kornelius yang jatuh pada 26 Juni 2024, Angeline Valesques membuat kejutan. Hal ini disampaikan Okan Kornelius saat ditemui di salah satu kawasan Jakarta. Dalam momen ulang tahun tersebut, pemain film Twivortiare itu juga diminta Angeline Valesques untuk memakai kemeja berwarna pink.     \"Itu memang warna kesukaan Angeline Valesques, ya kenapa nggak (dipakai) selama dia happy nggak apa-apa,\" ungkap Okan Kornelius, kemarin.     Okan Kornelius juga menyebut Angeline Valesques sudah menyiapkan kue ulang tahun berwarna pink. Okan Kornelius mengatakan kekasihnya itu memang kerap membuatnya kaget akan aksi spontannya. \"Ya dia memang orangnya usil banget, gue suka dibuat kaget sama tingkah-tingkah dia, but I love her so much,\" terang Okan Kornelius lagi.  Momen ulang tahun Okan Kornelius ini terlihat dalam Instagram miliknya. Di situ, Okan Kornelius membuat video singkat soal ulang tahun tersebut. \"The best birthday gathering dinner with all of my family. Thank you my beautiful @angelinevalesques who made this happened. Thank you for the amazing birthday gift, thank you for all the thoughts and caring. Hope we can grow old together. I love you so much and i thank GOD for all this amazing family,\" tulis Okan Kornelius dalam Instagram miliknya. Hubungan Okan Kornelius dengan Angeline Valesques memang sudah terjalin sejak beberapa waktu lalu. Keduanya mengaku sangat menyayangi satu sama lain.  Kemesraan keduanya juga kerap bikin netizen iri. Hal ini terlihat dalam kolom komentar Instagram keduanya. \"Ccok bngtt ko,,smoga cepat nikah dan bhgia smpai maut memisahkan,\" terang akun yetrs****. \"Berharap suatu saat bisa seperti kalian,\" beber akun lainnya.   \n","2                                                                                    Pedangdut Ayu Ting Ting rupanya sudah tak menjalin hubungan lagi dengan tunangannya, Muhammad Fardhana. Hal tersebut diungkapkan langsung oleh ayah Muhammad Fardhana, Dharsyi Akib. \"Kalau hubungan mereka ya memang sudah putus dan nggak berlanjut,\" kata Dharsyi Akib saat ditemui di kawasan Condet, Jakarta Selatan, Senin 1 Juli 2024.    Dharsyi Akib tak mengetahui alasan pasti soal putranya tak melanjutkan hubungannya dengan pelantun Sambalado itu. \"Mereka sudah sama-sama sepakat untuk mengakhiri nya. Sejak kapan putusnya pastinya saya gak tau yang tahu hanya mereka berdua. Mereka sudah sama-sama setuju mengakhiri sebagai orang tua harus menerima apapun keadaannya kan itu mungkin hikmah bagi itu,\" tutur Dharsyi Akib. Sebelum ada pernyataan dari sang ayah, kabar putusnya hubungan Ayu Ting Ting dan Muhammad Fardhana berawal dari dihapusnya foto Ayu Ting Ting di Instagram anggota TNI berpangkat Letnan Satu itu \"Kalau menghapus postingan Instagram tuh saya nggak tau, Putra saya kan lagi dinas negara ya harus diutamakan mungkin ada pertimbangan lain,\" ujar Dharsyi Akib. Meskipun perjodohan tidak terjadi, Dharsyi Akib mengaku kalau hubungannya dengan keluarga Ayu Ting Ting tetap baik-baik saja. \"Masalah hubungan kami tetap baik, namanya perjodohan kan itu urusan dengan Tuhan nah kita mau apa ke depannya kami berhubungan baik jangan sampai kalau dengan manusia dengan manusia harus baik nggak bisa kita jahat sama orang lain dan kita pun harus baik sama siapa pun,\" ucap Dharsyi Akib. Dia tak mempermasalahkan anaknya tidak jadi menikah dengan Ayu Ting Ting. Dia berharap semua urusan kedepannya bisa berjalan dengan lancarnya meskipun sudah masing-masing. \"Namanya manusia itu kan berusaha dan saya sebagai orang tua selalu berusaha semoga lancar dan semoga apapun dengan anak dan ternyata yang memang istilahnya katakanlah kandas lah nggak jadi tapi ini nggak masalah,\" pungkasnya.   \n","3                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Siapa sangka aktor Dion Wiyoko dulunya jago olahraga? Ternyata, sejak kecil dia sudah aktif berolahraga dan bahkan sampai mengikuti kejuaraan antar sekolah. Nggak heran kalau sampai sekarang dia masih rajin nge-gym dan jaga pola makan. Kecintaan Dion pada gaya hidup sehat ini yang kemudian mengantarkannya menjadi brand ambassador produk minuman isotonik Hydroplus.    Dalam acara peluncuran Hydroplus di Pekan Raya Jakarta (PRJ), Dion cerita kalau dia selalu memperhatikan asupan makanan dan minumannya untuk menunjang kesehariannya yang padat. \"Hidrasi yang baik itu penting banget, apalagi kalau banyak aktivitas dan sering olahraga,\" kata Dion. Dion pun mengajak anak muda untuk lebih aktif bergerak dan berolahraga. \"Ayo guys, jangan malas gerak! Olahraga itu banyak banget manfaatnya, loh. Nggak cuma bikin badan sehat, tapi juga mental jadi lebih positif,\" ajaknya. Yose Moriza, selaku Group Brand Head Hydroplus, menambahkan Hydroplus ini diformulasikan khusus untuk membantu tubuh terhidrasi dengan baik tanpa dehidrasi. Minuman ini juga rendah gula, tanpa pengawet dan pewarna, serta menyegarkan. \"Jadi, buat kamu yang suka beraktivitas dan berolahraga, Hydroplus ini bisa jadi pilihan tepat untuk menjaga tubuh tetap fit dan berenergi,\" jelas Yose. Dion pun menimpali, \"Hidrasi yang baik itu kunci utama untuk tetap sehat dan aktif. Jangan takut berkeringat, guys! Yuk, sama-sama kita jaga pola hidup sehat dengan banyak bergerak dan minum Hydroplus!\"    \n","4                                                                                                                                                                             Aktor dan mantan atlet basket, Denny Sumargo bersiap menjadi ayah karena Olivia Allan diprediksi melahirkan pada pertengan Juli 2024. Denny mengungkapkan kondisi janin di kandungan istri. \"Masih mau ditentukan ya last minute nanti (proses melahirkannya), soalnya bisa normal, bisa caesar. Tapi anaknya gede deh, beratnya sudah mau 3 kilogram dan agak panjang,\" kata Denny Sumargo ditemui di Gondangdia, Jakarta Pusat, Sabtu 29 Juni 2024. Cowok yang akrab disapa Densu itu terlihat sangat antusias menceritakan perkembangan janin pada kandungan Olivia Allan. Ada kalanya posisi janin masih terus memutar di dalam perut istrinya.    \"Suka muter-muter, kadang-kadang kepalanya ke bawah kadang naik ke atas kayak sungsang gitu. Karena kalau sungsang mesti caesar kan. Jadi masih nanti dilihat, cuma kita udah prepare,\" jelas Denny Sumargo. Denny Sumargo dan istri juga sudah menentukan rumah sakit untuk persalinan. Saat ini bintang film Perfect Strangers itu masih merasa semua berjalan baik-baik saja. \"Saya belum lihat (ketegangan) itu sih, mungkin belum terlalu dekat kali ya (waktu persalinan). Cuma dia sudah kelihatan kesulitan banget, perutnya gede banget, tidurnya sudah kesulitan, terus dia sering kebangun. Bayinya sudah gerak-gerak banget jadi dia kurang tidur aja,\" ceritanya mengenai kondisi istri. Melihat perjuangan istri mengandung, Denny Sumargo tak lantas diam saja. Dia mengaku kerap memberikan perhatian yang memang dibutuhkan oleh Olivia Allan. \"Ya standarlah nggak perlu banyak motivasi-motivasi berlebihan, cukup prepare, kadang-kadang elus perutnya ya, kadang-kadang kalau dia malam nggak enak tidurnya terus kebangun ya temenin,\" kata Denny Sumargo. Perjuangan Olivia Allan hingga akhirnya mengandung, tidaklah mudah. Oliva Allan mengalami 3 kali keguguran dan membuatnya sangat