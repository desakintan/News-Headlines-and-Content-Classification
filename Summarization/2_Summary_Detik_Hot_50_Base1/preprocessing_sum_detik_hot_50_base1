on Sentance"],"metadata":{"id":"zCxnlImQmjIg"}},{"cell_type":"code","source":["pre_data = df.copy()"],"metadata":{"id":"QE_91_WXCbvr"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import pandas as pd\n","import re\n","\n","# Fungsi untuk mengubah format tanggal\n","def format_date(text):\n","    # Pastikan input adalah string\n","    if isinstance(text, str):\n","        # Menggunakan regex untuk mencari tanggal dalam format (dd/mm/yyyy) dan (dd/mm)\n","        def replace_date(match):\n","            day = match.group(1)\n","            month = match.group(2)\n","            year = match.group(3) if match.lastindex == 3 else None\n","\n","            month_names = [\n","                \"Januari\", \"Februari\", \"Maret\", \"April\", \"Mei\", \"Juni\",\n","                \"Juli\", \"Agustus\", \"September\", \"Oktober\", \"November\", \"Desember\"\n","            ]\n","\n","            # Pengecekan untuk memastikan bulan valid\n","            month_index = int(month) - 1\n","            if 0 <= month_index < len(month_names):  # Cek apakah bulan dalam rentang valid\n","                if year:\n","                    return f\"{day} {month_names[month_index]} {year}\"  # Untuk format (dd/mm/yyyy)\n","                else:\n","                    return f\"{day} {month_names[month_index]}\"  # Untuk format (dd/mm)\n","            else:\n","                return match.group(0)  # Jika tidak valid, kembalikan string asli\n","\n","        # Mengganti setiap tanggal yang ditemukan\n","        text = re.sub(r'\\((\\d{1,2})/(\\d{1,2})/(\\d{4})\\)', replace_date, text)  # Format (dd/mm/yyyy)\n","        text = re.sub(r'\\((\\d{1,2})/(\\d{1,2})\\)', replace_date, text)  # Format (dd/mm)\n","        return text\n","    else:\n","        return text  # Kembalikan nilai asli jika bukan string\n","\n","# Mengubah format tanggal dalam kolom 'content'\n","pre_data['content'] = pre_data['content'].apply(format_date)"],"metadata":{"id":"kvV3ZuJjcrk1"},"exec